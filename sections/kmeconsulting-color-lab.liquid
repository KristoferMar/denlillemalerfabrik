{%- liquid
  assign combinations = shop.metaobjects['color_combination'].values
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cta_text = section.settings.cta_text
  assign bg_color = section.settings.background_color
-%}

<div class="section-background" style="background-color: {{ bg_color }};"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  {%- if eyebrow != blank or heading != blank or subheading != blank -%}
    <div class="kmeconsulting-color-lab__header">
      {%- if eyebrow != blank -%}
        <span class="kmeconsulting-color-lab__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="kmeconsulting-color-lab__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="kmeconsulting-color-lab__subheading">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if combinations.size > 0 -%}
    <div class="kmeconsulting-color-lab__grid">
      {%- for combo in combinations -%}
        <a href="{{ combo.system.url }}" class="kmeconsulting-color-lab__card" aria-label="{{ combo.name }}">
          <div class="kmeconsulting-color-lab__swatches">
            {%- for i in (1..5) -%}
              {%- case i -%}
                {%- when 1 -%}{%- assign pc = combo.paint_color_1.value -%}{%- assign fallback_hex = combo.color_1 -%}
                {%- when 2 -%}{%- assign pc = combo.paint_color_2.value -%}{%- assign fallback_hex = combo.color_2 -%}
                {%- when 3 -%}{%- assign pc = combo.paint_color_3.value -%}{%- assign fallback_hex = combo.color_3 -%}
                {%- when 4 -%}{%- assign pc = combo.paint_color_4.value -%}{%- assign fallback_hex = combo.color_4 -%}
                {%- when 5 -%}{%- assign pc = combo.paint_color_5.value -%}{%- assign fallback_hex = combo.color_5 -%}
              {%- endcase -%}
              {%- if pc != blank -%}
                <span class="kmeconsulting-color-lab__swatch" style="background-color: {{ pc.hex_color.value }};"></span>
              {%- elsif fallback_hex != blank -%}
                <span class="kmeconsulting-color-lab__swatch" style="background-color: {{ fallback_hex }};"></span>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <div class="kmeconsulting-color-lab__text">
            {%- if combo.name != blank -%}
              <h3 class="kmeconsulting-color-lab__name">{{ combo.name }}</h3>
            {%- endif -%}
            {%- if combo.description != blank -%}
              <p class="kmeconsulting-color-lab__description">{{ combo.description }}</p>
            {%- endif -%}
          </div>
          {%- if cta_text != blank -%}
            <span class="kmeconsulting-color-lab__cta">{{ cta_text }} <span aria-hidden="true">→</span></span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="kmeconsulting-color-lab__empty">Ingen farvekombinationer tilføjet endnu.</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .kmeconsulting-color-lab__header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .kmeconsulting-color-lab__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .kmeconsulting-color-lab__heading {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.1;
  }

  .kmeconsulting-color-lab__subheading {
    margin: 0;
    opacity: 0.65;
    font-size: 1.05rem;
    max-width: 36rem;
    line-height: 1.5;
  }

  .kmeconsulting-color-lab__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .kmeconsulting-color-lab__card {
    background: #ffffff;
    border-radius: 12px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease-out, box-shadow 0.25s ease-out;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    min-height: 240px;
  }

  .kmeconsulting-color-lab__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .kmeconsulting-color-lab__swatches {
    display: flex;
    gap: 6px;
    align-items: center;
    margin-bottom: 24px;
  }

  .kmeconsulting-color-lab__swatch {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .kmeconsulting-color-lab__text {
    flex: 1;
  }

  .kmeconsulting-color-lab__name {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .kmeconsulting-color-lab__description {
    font-size: 0.9rem;
    margin: 6px 0 0;
    opacity: 0.6;
    line-height: 1.5;
  }

  .kmeconsulting-color-lab__cta {
    margin-top: 24px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .kmeconsulting-color-lab__empty {
    text-align: center;
    opacity: 0.5;
    font-size: 0.9rem;
  }

  @media screen and (max-width: 989px) {
    .kmeconsulting-color-lab__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 549px) {
    .kmeconsulting-color-lab__grid {
      grid-template-columns: 1fr;
    }

    .kmeconsulting-color-lab__card {
      min-height: 0;
      padding: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Colorlab",
  "class": "kmeconsulting-color-lab",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etikettekst",
      "default": "Kuraterede paletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Colorlab"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Udforsk farvekombinationer der passer perfekt sammen, udvalgt af vores fagfolk."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Linktekst på kort",
      "default": "Se produkter i paletten"
    },
    {
      "type": "header",
      "content": "Sektionslayout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Baggrundsfarve",
      "default": "#f2ece1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        {
          "value": "page-width",
          "label": "Sidebredde"
        },
        {
          "value": "full-width",
          "label": "Fuld bredde"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Mellemrum",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Colorlab",
      "category": "Farver"
    }
  ]
}
{% endschema %}
