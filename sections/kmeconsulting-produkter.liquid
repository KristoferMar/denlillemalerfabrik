{%- liquid
  assign columns = section.settings.columns
  assign mobile_columns = section.settings.mobile_columns
  assign group_by_tag = section.settings.group_by_tag
  assign show_price_range = section.settings.show_price_range
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  {%- if section.settings.heading != blank -%}
    <h2 class="kmeconsulting-produkter__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.settings.description != blank -%}
    <p class="kmeconsulting-produkter__description">{{ section.settings.description }}</p>
  {%- endif -%}

  {%- comment -%} Paginate to access all products (Shopify limits to 50 without pagination) {%- endcomment -%}
  {%- paginate collections['all'].products by 250 -%}
  {%- assign all_products = collections['all'].products -%}

  {%- if group_by_tag -%}
    {%- assign tag_order = 'Pensler,Ruller,Sandpapir,Tape,Afdækning,Spartler,Anstrygere,Rullehåndtag,Malerbakker,Handsker,Kunstpensler,Tilbehør,Diverse' | split: ',' -%}

    {%- for tag in tag_order -%}
      {%- assign has_products = false -%}
      {%- for product in all_products -%}
        {%- if product.tags contains 'Lars Frey' and product.tags contains tag -%}
          {%- assign has_products = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_products -%}
        <div class="kmeconsulting-produkter__category" id="kategori-{{ tag | handleize }}">
          <h3 class="kmeconsulting-produkter__category-title">{{ tag }}</h3>
          <div
            class="kmeconsulting-produkter__grid"
            style="
              --columns: {{ columns }};
              --mobile-columns: {{ mobile_columns }};
            "
          >
            {%- for product in all_products -%}
              {%- if product.tags contains 'Lars Frey' and product.tags contains tag -%}
                <a href="{{ product.url }}" class="kmeconsulting-produkter__card">
                  <div class="kmeconsulting-produkter__card-image">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 600 }}"
                        alt="{{ product.title | escape }}"
                        width="300"
                        height="300"
                        loading="lazy"
                      >
                    {%- else -%}
                      <div class="kmeconsulting-produkter__card-placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </div>
                  <div class="kmeconsulting-produkter__card-info">
                    <h4 class="kmeconsulting-produkter__card-title">{{ product.title }}</h4>
                    {%- if show_price_range -%}
                      <span class="kmeconsulting-produkter__card-price">
                        {%- if product.price_varies -%}
                          Fra {{ product.price_min | money }}
                        {%- else -%}
                          {{ product.price | money }}
                        {%- endif -%}
                      </span>
                    {%- endif -%}
                    <span class="kmeconsulting-produkter__card-variants">
                      {{ product.variants.size }} varianter
                    </span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- else -%}
    <div
      class="kmeconsulting-produkter__grid"
      style="
        --columns: {{ columns }};
        --mobile-columns: {{ mobile_columns }};
      "
    >
      {%- for product in all_products -%}
        {%- if product.tags contains 'Lars Frey' -%}
          <a href="{{ product.url }}" class="kmeconsulting-produkter__card">
            <div class="kmeconsulting-produkter__card-image">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  width="300"
                  height="300"
                  loading="lazy"
                >
              {%- else -%}
                <div class="kmeconsulting-produkter__card-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
            <div class="kmeconsulting-produkter__card-info">
              <h4 class="kmeconsulting-produkter__card-title">{{ product.title }}</h4>
              {%- if show_price_range -%}
                <span class="kmeconsulting-produkter__card-price">
                  {%- if product.price_varies -%}
                    Fra {{ product.price_min | money }}
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </span>
              {%- endif -%}
              <span class="kmeconsulting-produkter__card-variants">
                {{ product.variants.size }} varianter
              </span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} Category quick-nav (sticky on desktop) {%- endcomment -%}
  {%- if group_by_tag and section.settings.show_category_nav -%}
    <nav class="kmeconsulting-produkter__nav" aria-label="Produktkategorier">
      {%- for tag in tag_order -%}
        {%- assign has_products = false -%}
        {%- for product in all_products -%}
          {%- if product.tags contains 'Lars Frey' and product.tags contains tag -%}
            {%- assign has_products = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if has_products -%}
          <a href="#kategori-{{ tag | handleize }}" class="kmeconsulting-produkter__nav-link">{{ tag }}</a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}
  {%- endpaginate -%}
</div>

<style>
  .kmeconsulting-produkter__heading {
    text-align: center;
    margin: 0;
  }

  .kmeconsulting-produkter__description {
    text-align: center;
    margin: 0;
    opacity: 0.7;
    max-width: 600px;
    align-self: center;
  }

  /* ── Category groups ── */
  .kmeconsulting-produkter__category {
    width: 100%;
    scroll-margin-top: calc(var(--header-height, 60px) + 24px);
    margin-top: 48px;
  }

  .kmeconsulting-produkter__category:first-child {
    margin-top: 0;
  }

  .kmeconsulting-produkter__category-title {
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.12);
    font-size: 1.6rem;
  }

  /* ── Product grid ── */
  .kmeconsulting-produkter__grid {
    display: grid;
    grid-template-columns: repeat(var(--mobile-columns, 2), 1fr);
    gap: 16px;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .kmeconsulting-produkter__grid {
      grid-template-columns: repeat(var(--columns, 4), 1fr);
      gap: 24px;
    }
  }

  /* ── Product card ── */
  .kmeconsulting-produkter__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.03);
    transition:
      transform var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out),
      box-shadow var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .kmeconsulting-produkter__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
  }

  /* ── Card image ── */
  .kmeconsulting-produkter__card-image {
    overflow: hidden;
    background: #fff;
  }

  .kmeconsulting-produkter__card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .kmeconsulting-produkter__card:hover .kmeconsulting-produkter__card-image img {
    transform: scale(1.05);
  }

  .kmeconsulting-produkter__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0.3;
  }

  .kmeconsulting-produkter__card-placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* ── Card info ── */
  .kmeconsulting-produkter__card-info {
    padding: 12px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .kmeconsulting-produkter__card-title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .kmeconsulting-produkter__card-price {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary, inherit);
  }

  .kmeconsulting-produkter__card-variants {
    font-size: 0.75rem;
    opacity: 0.5;
  }

  /* ── Category nav ── */
  .kmeconsulting-produkter__nav {
    position: fixed;
    top: calc(var(--header-height, 60px) + 24px);
    right: 24px;
    display: none;
    flex-direction: column;
    gap: 6px;
    background: var(--color-background, #fff);
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    border-radius: 8px;
    padding: 12px 16px;
    max-height: calc(100vh - var(--header-height, 60px) - 80px);
    overflow-y: auto;
    z-index: 10;
    box-shadow: 0 2px 12px rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
  }

  @media screen and (min-width: 1200px) {
    .kmeconsulting-produkter__nav {
      display: flex;
    }
  }

  .kmeconsulting-produkter__nav-link {
    font-size: 0.75rem;
    text-decoration: none;
    color: inherit;
    opacity: 0.6;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .kmeconsulting-produkter__nav-link:hover {
    opacity: 1;
  }


</style>

{% schema %}
{
  "name": "Produktkatalog",
  "class": "kmeconsulting-produkter",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Vores produkter"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Beskrivelse",
      "default": "Professionelt malerværktøj fra Lars Frey Farve og Lak"
    },
    {
      "type": "checkbox",
      "id": "group_by_tag",
      "label": "Grupper efter kategori",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price_range",
      "label": "Vis prisområde",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_category_nav",
      "label": "Vis kategori-navigation (desktop)",
      "default": true,
      "info": "Fast navigation i højre side på store skærme"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Kolonner (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Kolonner (mobil)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Sektionslayout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        { "value": "page-width", "label": "Sidebredde" },
        { "value": "full-width", "label": "Fuld bredde" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Mellemrum",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Produktkatalog",
      "category": "Produkter"
    }
  ]
}
{% endschema %}
