{%- liquid
  assign colors = shop.metaobjects['paint_color'].values
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- if section.settings.heading != blank -%}
    <h1 class="catalogue__heading">{{ section.settings.heading }}</h1>
  {%- endif -%}

  {%- if section.settings.subheading != blank -%}
    <p class="catalogue__subheading">{{ section.settings.subheading }}</p>
  {%- endif -%}

  <!-- Sticky nav for jumping between color families -->
  <nav class="catalogue__nav" id="catalogue-nav">
    {%- for block in section.blocks -%}
      {%- if block.type == 'color_family' and block.settings.family_name != blank -%}
        <a
          href="#catalogue-family-{{ block.id }}"
          class="catalogue__nav-link"
          style="--nav-color: {{ block.settings.accent_color }};"
        >
          <span class="catalogue__nav-dot" style="background-color: {{ block.settings.accent_color }};"></span>
          {{ block.settings.family_name }}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </nav>

  <div class="catalogue__families">
    {%- for block in section.blocks -%}
      {%- if block.type == 'color_family' -%}
        {%- liquid
          assign family_name = block.settings.family_name
          assign family_colors = ''
          assign family_count = 0
        -%}

        {%- assign is_even = forloop.index | modulo: 2 -%}
        <section
          class="catalogue__family"
          id="catalogue-family-{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="catalogue__family-content{% if is_even == 0 %} catalogue__family-content--reversed{% endif %}">
            {%- comment -%} Left side: header + color swatches {%- endcomment -%}
            <div class="catalogue__colors-panel">
              <div class="catalogue__family-header">
                <div class="catalogue__family-stripe" style="background-color: {{ block.settings.accent_color }};"></div>
                <h2 class="catalogue__family-title">{{ family_name }}</h2>
                {%- if block.settings.family_description != blank -%}
                  <p class="catalogue__family-description">{{ block.settings.family_description }}</p>
                {%- endif -%}
              </div>

              <div class="catalogue__colors-grid">
                {%- comment -%} Collect matching colors, then sort by dlm_code (light→dark) {%- endcomment -%}
                {%- assign family_codes = '' -%}
                {%- for color in colors -%}
                  {%- if color.color_family == family_name -%}
                    {%- unless family_codes == '' -%}{%- assign family_codes = family_codes | append: ',' -%}{%- endunless -%}
                    {%- assign family_codes = family_codes | append: color.dlm_code -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- assign sorted_codes = family_codes | split: ',' | sort -%}
                {%- for code in sorted_codes -%}
                  {%- for color in colors -%}
                    {%- if color.dlm_code == code -%}
                      <div class="catalogue__color-item">
                        <span
                          class="catalogue__color-swatch"
                          style="background-color: {{ color.hex_color }};"
                        ></span>
                        <span class="catalogue__color-name">{{ color.name }}</span>
                        <span class="catalogue__color-code">{{ color.dlm_code }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
              </div>
            </div>

            {%- comment -%} Right side: 2 squares stacked + 1 portrait {%- endcomment -%}
            {%- liquid
              assign prefix = block.settings.image_prefix
              assign img1_file = 'katalog-' | append: prefix | append: '-1.png'
              assign img2_file = 'katalog-' | append: prefix | append: '-2.png'
              assign img3_file = 'katalog-' | append: prefix | append: '-3.png'
            -%}
            <div class="catalogue__images-panel">
              <div class="catalogue__images-squares">
                <div class="catalogue__image-wrapper catalogue__image-wrapper--square">
                  <img
                    src="{{ img1_file | asset_url }}"
                    alt="{{ family_name }} inspiration 1"
                    class="catalogue__image"
                    loading="lazy"
                  >
                </div>
                <div class="catalogue__image-wrapper catalogue__image-wrapper--square">
                  <img
                    src="{{ img2_file | asset_url }}"
                    alt="{{ family_name }} inspiration 2"
                    class="catalogue__image"
                    loading="lazy"
                  >
                </div>
              </div>
              <div class="catalogue__image-wrapper catalogue__image-wrapper--portrait">
                <img
                  src="{{ img3_file | asset_url }}"
                  alt="{{ family_name }} inspiration 3"
                  class="catalogue__image"
                  loading="lazy"
                >
              </div>
            </div>
          </div>
        </section>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  .catalogue__heading {
    text-align: center;
    margin: 0 0 8px;
  }

  .catalogue__subheading {
    text-align: center;
    margin: 0 0 32px;
    opacity: 0.65;
    max-width: 600px;
    margin-inline: auto;
  }

  /* --- Navigation --- */
  .catalogue__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    padding: 16px 0;
    margin-bottom: 48px;
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: var(--color-background, #fff);
    border-bottom: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
  }

  .catalogue__nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 100px;
    text-decoration: none;
    color: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    transition: border-color 0.2s ease, transform 0.15s ease;
  }

  .catalogue__nav-link:hover {
    border-color: var(--nav-color, currentColor);
    transform: translateY(-1px);
  }

  .catalogue__nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* --- Family section --- */
  .catalogue__families {
    display: flex;
    flex-direction: column;
    gap: 120px;
  }

  .catalogue__family {
    scroll-margin-top: 80px;
  }

  .catalogue__family-header {
    margin-bottom: 24px;
  }

  .catalogue__family-stripe {
    width: 48px;
    height: 4px;
    border-radius: 2px;
    margin-bottom: 12px;
  }

  .catalogue__family-title {
    margin: 0 0 8px;
    font-size: 1.8rem;
  }

  .catalogue__family-description {
    margin: 0;
    opacity: 0.6;
    max-width: 500px;
    line-height: 1.6;
  }

  /* --- Content layout (colors left, images right) --- */
  .catalogue__family-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media screen and (min-width: 990px) {
    .catalogue__family-content {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      max-width: 900px;
      margin: 0 auto;
    }

    .catalogue__family-content--reversed .catalogue__colors-panel {
      order: 2;
    }

    .catalogue__family-content--reversed .catalogue__images-panel {
      order: 1;
    }
  }

  /* --- Colors panel (left) --- */
  .catalogue__colors-panel {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .catalogue__colors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    justify-items: center;
  }

  @media screen and (max-width: 989px) {
    .catalogue__colors-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }

  .catalogue__color-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
  }

  .catalogue__color-swatch {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
    background-size: cover;
    background-position: center;
    transition: transform 0.2s ease;
  }

  .catalogue__color-item:hover .catalogue__color-swatch {
    transform: scale(1.05);
  }

  @media screen and (min-width: 990px) {
    .catalogue__color-swatch {
      width: 120px;
      height: 120px;
    }
  }

  .catalogue__color-name {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .catalogue__color-code {
    font-size: 0.8rem;
    opacity: 0.45;
    font-family: monospace;
    letter-spacing: 0.02em;
  }

  /* --- Images panel (right): 2 squares + 1 portrait --- */
  .catalogue__images-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 12px;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    align-self: end;
  }

  .catalogue__images-squares {
    display: contents;
  }

  .catalogue__image-wrapper {
    border-radius: 12px;
    overflow: hidden;
  }

  .catalogue__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .catalogue__image-wrapper--square {
    aspect-ratio: 1 / 1;
  }

  .catalogue__image-wrapper--portrait {
    grid-row: 1 / -1;
    grid-column: 2;
  }
</style>

<script>
  document.querySelectorAll('.catalogue__nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Farvekatalog (Showroom)",
  "class": "kmeconsulting-catalogue",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Farvekatalog"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Udforsk vores farvepaletter og lad dig inspirere til dit næste maleprojekt."
    },
    {
      "type": "header",
      "content": "Sektionslayout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        { "value": "page-width", "label": "Sidebredde" },
        { "value": "full-width", "label": "Fuld bredde" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "color_family",
      "name": "Farvefamilie",
      "settings": [
        {
          "type": "text",
          "id": "family_name",
          "label": "Farvefamilie",
          "info": "Skal matche color_family fra farve-metaobjekterne (f.eks. Grøn, Blå, Gul, Rød)"
        },
        {
          "type": "textarea",
          "id": "family_description",
          "label": "Beskrivelse",
          "info": "Kort stemningsbeskrivelse af farvefamilien"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accentfarve",
          "info": "Bruges til accent-stripe og navigation",
          "default": "#2E8B57"
        },
        {
          "type": "header",
          "content": "Inspirationsbilleder"
        },
        {
          "type": "text",
          "id": "image_prefix",
          "label": "Billed-præfiks",
          "info": "Filnavn-præfiks i assets-mappen (f.eks. 'hvid' → katalog-hvid-1.png, katalog-hvid-2.png, katalog-hvid-3.png)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Farvekatalog (Showroom)",
      "category": "Farver",
      "blocks": [
        {
          "type": "color_family",
          "settings": {
            "family_name": "Grøn",
            "family_description": "Naturens rolige toner. Grønne nuancer bringer harmoni og friskhed ind i ethvert rum.",
            "accent_color": "#2E8B57"
          }
        },
        {
          "type": "color_family",
          "settings": {
            "family_name": "Blå",
            "family_description": "Fra himmelblå til dyb midnat. Blå skaber ro og elegance.",
            "accent_color": "#4A90D9"
          }
        },
        {
          "type": "color_family",
          "settings": {
            "family_name": "Gul",
            "family_description": "Varme og livlige toner der fylder rummet med energi og optimisme.",
            "accent_color": "#D4A017"
          }
        },
        {
          "type": "color_family",
          "settings": {
            "family_name": "Rød",
            "family_description": "Modige og karakterfulde farver der giver personlighed og varme.",
            "accent_color": "#CC6644"
          }
        },
        {
          "type": "color_family",
          "settings": {
            "family_name": "Hvid",
            "family_description": "Klassiske hvide toner der åbner rummet og skaber luft og lethed.",
            "accent_color": "#F5F0EB"
          }
        },
        {
          "type": "color_family",
          "settings": {
            "family_name": "Grå",
            "family_description": "Sofistikerede og tidløse gråtoner der passer til enhver stil.",
            "accent_color": "#8E8E8E"
          }
        },
        {
          "type": "color_family",
          "settings": {
            "family_name": "Sort",
            "family_description": "Dyb og dramatisk. Sort tilføjer dybde og kontrast.",
            "accent_color": "#1A1A1A"
          }
        }
      ]
    }
  ]
}
{% endschema %}
