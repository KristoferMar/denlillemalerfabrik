<div
  class="kmeconsulting-hero section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  <div class="kmeconsulting-hero__inner">
    <div class="kmeconsulting-hero__content">
      {%- if section.settings.title != blank -%}
        <h2 class="kmeconsulting-hero__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="kmeconsulting-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="kmeconsulting-hero__buttons">
        {%- if section.settings.button_label_1 != blank -%}
          <a
            href="{{ section.settings.button_link_1 }}"
            class="button"
          >
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_label_2 != blank -%}
          <a
            href="{{ section.settings.button_link_2 }}"
            class="button-secondary"
          >
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="kmeconsulting-hero__image">
      <img
        src="{{ 'product-preview-hero-image-no-bg.png' | asset_url }}"
        alt="Den Lille Malerfabrik produkter"
        loading="eager"
        width="600"
        height="600"
      >
    </div>
  </div>
</div>

<style>
  .kmeconsulting-hero {
    padding: 0 !important;
  }

  .kmeconsulting-hero__inner {
    width: 100%;
    padding: 60px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    padding-left: 10%;
  }

  .kmeconsulting-hero__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 560px;
    flex-shrink: 0;
  }

  .kmeconsulting-hero__image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 0;
  }

  .kmeconsulting-hero__image img {
    max-width: 100%;
    height: auto;
    display: block;
    max-height: 560px;
    object-fit: contain;
  }

  .kmeconsulting-hero__title {
    margin: 0;
    color: var(--color-foreground);
  }

  .kmeconsulting-hero__subtitle {
    margin: 0;
    opacity: 0.7;
    color: var(--color-foreground);
    font-size: 0.9rem;
  }

  .kmeconsulting-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 8px;
  }

  @media screen and (max-width: 749px) {
    .kmeconsulting-hero__inner {
      padding: 40px 0;
      flex-direction: column;
      gap: 32px;
    }

    .kmeconsulting-hero__content {
      max-width: 100%;
    }

    .kmeconsulting-hero__image {
      justify-content: center;
    }

    .kmeconsulting-hero__image img {
      max-height: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "KME Hero",
  "class": "kmeconsulting-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Professionel maling. Korrekt resultat."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Udviklet af fagfolk - til både private, professionelle og arkitekter."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Button 1 label",
      "default": "Se farver"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 label",
      "default": "Beregn korrekt mængde"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "KME Hero"
    }
  ]
}
{% endschema %}
