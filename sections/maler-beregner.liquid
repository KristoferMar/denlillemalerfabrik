{%- liquid
  assign current_step = 1
-%}

{% render 'beregner-config' %}

<div
  class="maler-beregner section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  id="maler-beregner"
  data-step="{{ current_step }}"
>
  <!-- Header -->
  <div class="maler-beregner__header">
    <h1 class="maler-beregner__title">BEREGNER</h1>
    <p class="maler-beregner__subtitle">Trin <span class="maler-beregner__step-current">1</span> af 3 &middot; <span class="maler-beregner__step-label">Vælg behandling</span></p>
  </div>

  <!-- Step Indicator -->
  <div class="maler-beregner__steps">
    <button class="maler-beregner__step-btn maler-beregner__step-btn--active" data-step="1">
      1. Vælg behandling
    </button>
    <button class="maler-beregner__step-btn" data-step="2" disabled>
      2. Areal & valg
    </button>
    <button class="maler-beregner__step-btn" data-step="3" disabled>
      3. Resultat
    </button>
  </div>

  <!-- Step 1: Vælg behandling -->
  <div class="maler-beregner__panel" data-panel="1">
    <p class="maler-beregner__description">
      Vælg den behandling, der matcher dit underlag. Behandlingen styrer automatisk materialer, lag og værktøj i beregneren.
    </p>

    <!-- Indvendigt -->
    <div class="maler-beregner__category">
      <h2 class="maler-beregner__category-title">Indvendigt</h2>
      <div class="maler-beregner__grid">
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="ny-gips-vaeg" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="4" y1="12" x2="20" y2="12"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Ny gips – væg</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="tidligere-malet-gips-vaeg" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="12" y1="2" x2="12" y2="22"/><path d="M7 6v4M16 7v5"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Tidligere malet gips – væg</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="nyt-gipsloft" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8h20"/><path d="M5 8L3 20h18l-2-12"/><path d="M9 8V5h6v3"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Nyt gipsloft</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="tidligere-malet-loft" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8h20"/><path d="M5 8L3 20h18l-2-12"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="8" y1="16" x2="16" y2="16"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Tidligere malet loft</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="vaev-filt-gips-beton" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7c4 0 4 4 8 4s4-4 8-4"/><path d="M2 13c4 0 4 4 8 4s4-4 8-4"/><path d="M2 19c4 0 4 4 8 4s4-4 8-4"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Væv / filt – gips/beton</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="beton-mur-indvendigt" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="1"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="2" y1="16" x2="22" y2="16"/><line x1="12" y1="4" x2="12" y2="10"/><line x1="7" y1="10" x2="7" y2="16"/><line x1="17" y1="10" x2="17" y2="16"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Beton / mur – indvendigt</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="trae-indvendigt" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="14" x2="21" y2="14"/><circle cx="12" cy="11" r="2"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Træ – indvendigt</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="koekkenlaager-inventar" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="9" y1="10" x2="9" y2="14"/><line x1="15" y1="10" x2="15" y2="14"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Køkkenlåger & inventar</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="metal-indvendigt" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="7.5" cy="7.5" r="1.5"/><circle cx="16.5" cy="7.5" r="1.5"/><circle cx="7.5" cy="16.5" r="1.5"/><circle cx="16.5" cy="16.5" r="1.5"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Metal – indvendigt</span>
          </span>
        </label>
      </div>
    </div>

    <!-- Udvendigt -->
    <div class="maler-beregner__category">
      <h2 class="maler-beregner__category-title">Udvendigt</h2>
      <div class="maler-beregner__grid">
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="facade-ny-afrenset" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-8 9 8"/><path d="M5 12v8h14v-8"/><rect x="10" y="14" width="4" height="6"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Facade – ny/afrenset</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="facade-tidligere-malet" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-8 9 8"/><path d="M5 12v8h14v-8"/><rect x="10" y="14" width="4" height="6"/><path d="M8 14v3"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Facade – tidligere malet</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="udvendigt-trae" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="4" x2="5" y2="20"/><line x1="10" y1="3" x2="10" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/><line x1="20" y1="3" x2="20" y2="20"/><line x1="3" y1="10" x2="22" y2="10"/><line x1="3" y1="16" x2="22" y2="16"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Udvendigt træ</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="betongulv-bolig" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="20" height="12" rx="1"/><line x1="12" y1="8" x2="12" y2="20"/><line x1="2" y1="14" x2="22" y2="14"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Betongulv – bolig</span>
          </span>
        </label>
        <label class="maler-beregner__card">
          <input type="checkbox" name="treatment" value="betongulv-industri-vaerksted" class="maler-beregner__checkbox">
          <span class="maler-beregner__card-inner">
            <span class="maler-beregner__card-symbol">
              <svg class="maler-beregner__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="20" height="12" rx="1"/><line x1="8" y1="8" x2="8" y2="20"/><line x1="16" y1="8" x2="16" y2="20"/><line x1="2" y1="14" x2="22" y2="14"/></svg>
              <svg class="maler-beregner__checkmark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </span>
            <span class="maler-beregner__card-label">Betongulv – industri / værksted</span>
          </span>
        </label>
      </div>
    </div>

    <!-- Har du brug for hjælp? -->
    <div class="maler-beregner__help">
      <h3 class="maler-beregner__help-title">Har du brug for hjælp?</h3>
      <div class="maler-beregner__help-grid">
        <a href="#" class="maler-beregner__help-link">Hvad skal du male?</a>
        <a href="#" class="maler-beregner__help-link">Se alle behandlingsforslag</a>
        <a href="/pages/kontakt" class="maler-beregner__help-link">Kontakt os for rådgivning</a>
      </div>
    </div>

    <!-- Navigation -->
    <div class="maler-beregner__nav">
      <button class="maler-beregner__nav-btn maler-beregner__nav-btn--next" id="beregner-next" disabled>
        Næste: Areal & valg
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>

  <!-- Step 2: Areal & valg -->
  <div class="maler-beregner__panel" data-panel="2" style="display:none;">
    <p class="maler-beregner__description">
      Angiv hvor mange kvadratmeter du skal male for hver valgt behandling.
    </p>

    <div class="maler-beregner__area-list" id="beregner-area-list">
      <!-- Dynamically populated by JS -->
    </div>

    <!-- Navigation -->
    <div class="maler-beregner__nav maler-beregner__nav--between">
      <button class="maler-beregner__nav-btn maler-beregner__nav-btn--back" id="beregner-back-1">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Tilbage
      </button>
      <button class="maler-beregner__nav-btn maler-beregner__nav-btn--next" id="beregner-next-2" disabled>
        Næste: Resultat
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>

  <!-- Step 3: Resultat -->
  <div class="maler-beregner__panel" data-panel="3" style="display:none;">
    <p class="maler-beregner__description">
      Her er din materialeberegning baseret på de valgte behandlinger og arealer.
    </p>

    <div class="maler-beregner__results" id="beregner-results">
      <!-- Dynamically populated by JS -->
    </div>

    <!-- Navigation -->
    <div class="maler-beregner__nav maler-beregner__nav--between">
      <button class="maler-beregner__nav-btn maler-beregner__nav-btn--back" id="beregner-back-2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Tilbage
      </button>
      <button class="maler-beregner__nav-btn maler-beregner__nav-btn--next" id="beregner-restart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
        Start forfra
      </button>
    </div>
  </div>
</div>

<style>
  .maler-beregner {
    max-width: var(--normal-page-width, 120rem);
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
    font-family: var(--font-body--family);
    color: var(--color-foreground);
  }

  /* Header */
  .maler-beregner__header {
    margin-bottom: 3rem;
    padding: 3rem 3.2rem;
    background: linear-gradient(135deg, rgb(var(--color-foreground-rgb) / 0.03) 0%, rgb(var(--color-foreground-rgb) / 0.07) 100%);
    border-radius: 14px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.06);
  }

  .maler-beregner__title {
    font-family: var(--font-heading--family);
    font-size: 3.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0 0 0.4rem;
  }

  .maler-beregner__subtitle {
    font-size: 1.4rem;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin: 0;
  }

  /* Step Indicator */
  .maler-beregner__steps {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 3rem;
    padding: 0.6rem;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    border-radius: 10px;
    border: none;
  }

  .maler-beregner__step-btn {
    flex: 1;
    padding: 1.1rem 1.6rem;
    font-size: 1.35rem;
    font-family: var(--font-body--family);
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-foreground-rgb) / 0.35);
    transition: all 0.25s ease;
    text-align: center;
    border-radius: 7px;
    font-weight: 500;
  }

  .maler-beregner__step-btn:first-child {
    border-radius: 7px;
  }

  .maler-beregner__step-btn:last-child {
    border-radius: 7px;
  }

  .maler-beregner__step-btn--active {
    color: var(--color-foreground);
    font-weight: 600;
    background: var(--color-background);
    box-shadow: 0 1px 4px rgb(var(--color-foreground-rgb) / 0.1), 0 0 0 1px rgb(var(--color-foreground-rgb) / 0.06);
  }

  .maler-beregner__step-btn--completed {
    color: rgb(var(--color-foreground-rgb) / 0.6);
    cursor: pointer;
  }

  .maler-beregner__step-btn--completed:hover {
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .maler-beregner__step-btn:disabled {
    cursor: not-allowed;
  }

  /* Description */
  .maler-beregner__description {
    font-size: 1.5rem;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    margin: 0 0 3rem;
    max-width: 60rem;
    line-height: 1.6;
  }

  /* Category */
  .maler-beregner__category {
    margin-bottom: 3.6rem;
  }

  .maler-beregner__category-title {
    font-family: var(--font-heading--family);
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
    padding-left: 0.2rem;
  }

  .maler-beregner__category::before {
    content: '';
    display: block;
    width: 3.2rem;
    height: 3px;
    background: var(--color-foreground);
    border-radius: 2px;
    margin-bottom: 1.2rem;
  }

  /* Grid */
  .maler-beregner__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .maler-beregner__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .maler-beregner__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Card */
  .maler-beregner__card {
    position: relative;
    cursor: pointer;
    display: flex;
  }

  .maler-beregner__checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .maler-beregner__card-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem 1.6rem;
    border: 1.5px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-radius: 10px;
    transition: all 0.25s ease;
