<script>
  (function() {
    var container = document.getElementById('maler-beregner');
    if (!container) return;

    var config = {};
    try { config = JSON.parse(document.getElementById('beregner-config').textContent); } catch(e) {}

    var checkboxes = container.querySelectorAll('.mb__checkbox');
    var nextBtn = container.querySelector('#beregner-next');
    var nextBtn2 = container.querySelector('#beregner-next-2');
    var backBtn1 = container.querySelector('#beregner-back-1');
    var backBtn2 = container.querySelector('#beregner-back-2');
    var restartBtn = container.querySelector('#beregner-restart');
    var stepEls = container.querySelectorAll('.mb__step');
    var areaList = container.querySelector('#beregner-area-list');
    var resultsContainer = container.querySelector('#beregner-results');
    var ctaBar = container.querySelector('#beregner-cta-bar');
    var ctaHint = container.querySelector('#beregner-cta-hint');

    var stepLabels = { 1: 'Behandling', 2: 'Areal', 3: 'Resultat' };

    var iconIndvendigt = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>';
    var iconUdvendigt = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>';

    var areaValues = {};
    var currentStep = 1;

    function getSelectedTreatments() {
      return Array.from(checkboxes).filter(function(cb) { return cb.checked; }).map(function(cb) { return cb.value; });
    }

    function updateCta() {
      var selected = getSelectedTreatments();
      nextBtn.disabled = selected.length === 0;
      if (selected.length === 0) {
        ctaHint.textContent = 'Vælg mindst én behandling';
      } else {
        var names = selected.map(function(v) {
          var t = config.treatments && config.treatments[v];
          return t ? t.name : v;
        });
        ctaHint.textContent = names.length + (names.length === 1 ? ' behandling valgt' : ' behandlinger valgt');
      }
    }

    function updateNextButton2() {
      var inputs = areaList.querySelectorAll('.mb__area-input');
      var allFilled = Array.from(inputs).every(function(input) { return parseFloat(input.value) > 0; });
      nextBtn2.disabled = !allFilled;
    }

    function buildAreaList() {
      var selected = getSelectedTreatments();
      areaList.innerHTML = '';
      selected.forEach(function(value) {
        var t = config.treatments && config.treatments[value];
        var name = t ? t.name : value;
        var cat = t ? (t.category === 'udvendigt' ? 'Udvendigt' : 'Indvendigt') : '';
        var icon = cat === 'Udvendigt' ? iconUdvendigt : iconIndvendigt;
        var savedValue = areaValues[value] || '';
        var card = document.createElement('div');
        card.className = 'mb__area-card';
        card.innerHTML =
          '<div class="mb__area-card-info">' +
            '<div class="mb__area-card-icon">' + icon + '</div>' +
            '<div class="mb__area-card-text">' +
              '<span class="mb__area-card-title">' + name + '</span>' +
              '<span class="mb__area-card-tag">' + cat + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="mb__area-input-wrap">' +
            '<input type="number" class="mb__area-input" data-treatment="' + value + '" placeholder="0" min="0" step="0.5" value="' + savedValue + '">' +
            '<span class="mb__area-unit">m²</span>' +
          '</div>';
        areaList.appendChild(card);
      });
      areaList.querySelectorAll('.mb__area-input').forEach(function(input) {
        input.addEventListener('input', function() {
          areaValues[this.dataset.treatment] = this.value;
          updateNextButton2();
        });
      });
      updateNextButton2();
    }

    var productCache = {};
    function fetchProduct(handle) {
      if (productCache[handle]) return productCache[handle];
      if (!handle || handle.indexOf('TODO') === 0) { productCache[handle] = Promise.resolve(null); return productCache[handle]; }
      productCache[handle] = fetch('/products/' + handle + '.json')
        .then(function(res) { return res.ok ? res.json() : null; })
        .then(function(data) { return data && data.product ? data.product : null; })
        .catch(function() { return null; });
      return productCache[handle];
    }

    function formatMoney(cents) { return (cents / 100).toFixed(2).replace('.', ',') + ' kr.'; }

    function calculateResults() {
      var selected = getSelectedTreatments();
      var results = [];
      selected.forEach(function(treatmentKey) {
        var t = config.treatments && config.treatments[treatmentKey];
        if (!t) return;
        var area = parseFloat(areaValues[treatmentKey]) || 0;
        var coats = t.coats || 2;
        var products = t.products || {};
        var items = [];
        Object.keys(products).forEach(function(key) {
          var p = products[key];
          var qty = p.per_m2 > 0 ? Math.ceil(area * p.per_m2 * coats * 10) / 10 : (p.flat_qty || 1);
          items.push({ label: p.label, handle: p.handle, role: p.role, qty: qty, unit: p.per_m2 > 0 ? 'L' : 'stk', isTodo: p.handle.indexOf('TODO') === 0 });
        });
        results.push({ name: t.name, category: t.category === 'udvendigt' ? 'Udvendigt' : 'Indvendigt', area: area, coats: coats, coverage: t.coverage_m2_per_liter, items: items });
      });
      return results;
    }

    function renderResults() {
      var results = calculateResults();
      resultsContainer.innerHTML = '<p class="mb__description">Henter produktdata...</p>';
      var allHandles = [];
      results.forEach(function(g) { g.items.forEach(function(i) { if (allHandles.indexOf(i.handle) === -1) allHandles.push(i.handle); }); });

      Promise.all(allHandles.map(fetchProduct)).then(function(products) {
        var productMap = {};
        allHandles.forEach(function(h, i) { productMap[h] = products[i]; });
        resultsContainer.innerHTML = '';
        var totalArea = 0, hasTodo = false;
        var roleLabels = { primer: 'Primer', paint: 'Maling', tool: 'Værktøj', accessory: 'Tilbehør' };
        var excludedKeys = new Set();
        var removeIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6M14 11v6"></path><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"></path></svg>';
        var undoIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>';
        var addIcon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>';

        results.forEach(function(group, gi) {
          totalArea += group.area;
          var html = '<div class="mb__result-group"><div class="mb__result-group-header"><span class="mb__result-group-title">' + group.name + '</span><span class="mb__result-group-area">' + group.area + ' m² &middot; ' + group.coats + ' lag &middot; ' + group.coverage + ' m²/L</span></div><table class="mb__result-table"><thead><tr><th>Produkt</th><th>Type</th><th>Mængde</th><th></th></tr></thead><tbody>';

          group.items.forEach(function(item, ii) {
            var rowKey = gi + '-' + ii;
            var sp = productMap[item.handle];
            var cell = '';
            if (sp) {
              var img = sp.image ? sp.image.src.replace(/\.([a-z]+)$/, '_100x100.$1') : '';
              var imgTag = img ? '<img class="mb__result-product-img" src="' + img + '" alt="' + sp.title + '" loading="lazy">' : '<div class="mb__result-product-placeholder"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>';
              var price = sp.variants && sp.variants[0] ? formatMoney(parseInt(sp.variants[0].price * 100)) : '';
              cell = '<div class="mb__result-product">' + imgTag + '<div class="mb__result-product-info"><span class="mb__result-product-title"><a href="/products/' + item.handle + '">' + sp.title + '</a></span>' + (price ? '<span class="mb__result-product-price">' + price + '</span>' : '') + '</div></div>';
            } else {
              hasTodo = true;
              cell = '<div class="mb__result-product"><div class="mb__result-product-placeholder"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div><div class="mb__result-product-info"><span class="mb__result-product-title">' + item.label + '</span><span class="mb__result-todo">(produkt mangler)</span></div></div>';
            }
            var removeBtn = sp ? '<button type="button" class="mb__result-remove" data-row-key="' + rowKey + '" aria-label="Fjern fra listen" title="Fjern fra listen">' + removeIcon + '</button>' : '';
            html += '<tr data-row-key="' + rowKey + '"><td>' + cell + '</td><td><span class="mb__result-role mb__result-role--' + item.role + '">' + (roleLabels[item.role] || item.role) + '</span></td><td><span class="mb__result-qty">' + item.qty + ' ' + item.unit + '</span></td><td class="mb__result-action-cell">' + removeBtn + '</td></tr>';
          });
          html += '</tbody></table></div>';
          resultsContainer.innerHTML += html;
        });

        function computeCartItems() {
          var items = [];
          results.forEach(function(g, gi) { g.items.forEach(function(i, ii) {
            var key = gi + '-' + ii;
            if (excludedKeys.has(key)) return;
            var sp = productMap[i.handle];
            if (sp && sp.variants && sp.variants[0]) {
              var vid = sp.variants[0].id;
              var ex = items.find(function(c) { return c.id === vid; });
              if (ex) ex.quantity += Math.ceil(i.qty); else items.push({ id: vid, quantity: Math.ceil(i.qty) });
            }
          }); });
          return items;
        }

        var currentCartItems = computeCartItems();

        if (currentCartItems.length > 0) {
          resultsContainer.innerHTML += '<button class="mb__result-add-all" id="beregner-add-to-cart">' + addIcon + '<span class="mb__result-add-all-label">Læg alle produkter i kurven (' + currentCartItems.length + ')</span></button>' + (hasTodo ? '<p class="mb__result-add-notice">Produkter markeret "(produkt mangler)" tilføjes ikke.</p>' : '') + '<div id="beregner-cart-feedback"></div>';
        }

        resultsContainer.innerHTML += '<div class="mb__result-summary"><p class="mb__result-summary-title">Samlet areal: ' + totalArea + ' m²</p><p class="mb__result-summary-text">Beregningen er et estimat baseret på standardforbrug. Det faktiske forbrug kan variere afhængigt af underlag, sugning og påføringsmetode.' + (hasTodo ? ' Produkter markeret "(produkt mangler)" er endnu ikke tilgængelige.' : '') + '</p></div>';

        var addBtn = document.getElementById('beregner-add-to-cart');
        var addBtnLabel = addBtn ? addBtn.querySelector('.mb__result-add-all-label') : null;
        var feedbackEl = document.getElementById('beregner-cart-feedback');

        function refreshAddButton() {
          currentCartItems = computeCartItems();
          if (!addBtn) return;
          if (currentCartItems.length === 0) {
            addBtn.disabled = true;
            if (addBtnLabel) addBtnLabel.textContent = 'Ingen produkter valgt';
          } else {
            addBtn.disabled = false;
            if (addBtnLabel) addBtnLabel.textContent = 'Læg alle produkter i kurven (' + currentCartItems.length + ')';
          }
        }

        resultsContainer.querySelectorAll('.mb__result-remove').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var key = this.dataset.rowKey;
            var row = resultsContainer.querySelector('tr[data-row-key="' + key + '"]');
            if (excludedKeys.has(key)) {
              excludedKeys.delete(key);
              if (row) row.classList.remove('mb__result-row--excluded');
              this.setAttribute('aria-label', 'Fjern fra listen');
              this.setAttribute('title', 'Fjern fra listen');
              this.innerHTML = removeIcon;
            } else {
              excludedKeys.add(key);
              if (row) row.classList.add('mb__result-row--excluded');
              this.setAttribute('aria-label', 'Tilføj til listen igen');
              this.setAttribute('title', 'Tilføj til listen igen');
              this.innerHTML = undoIcon;
            }
            refreshAddButton();
          });
        });

        if (addBtn) {
          addBtn.addEventListener('click', function() {
            if (addBtn.disabled || currentCartItems.length === 0) return;
            addBtn.disabled = true;
            if (addBtnLabel) addBtnLabel.textContent = 'Tilføjer…';
            fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ items: currentCartItems }) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (d.status && d.status === 422) throw new Error(d.description || 'Kunne ikke tilføje');
              feedbackEl.innerHTML = '<div class="mb__result-add-success"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Tilføjet! <a href="/cart">Gå til kurv</a></div>';
              addBtn.style.display = 'none';
              // Re-fetch cart then notify the theme via its own cart:update event,
              // so the drawer and cart-icon components re-render themselves.
              fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
                document.querySelectorAll('.cart-count, [data-cart-count], .header__cart-count').forEach(function(el) { el.textContent = cart.item_count; });
                var cartUpdate = new CustomEvent('cart:update', {
                  bubbles: true,
                  detail: { resource: cart, sourceId: 'maler-beregner', data: {} },
                });
                document.dispatchEvent(cartUpdate);
              });
            })
            .catch(function(err) {
              addBtn.disabled = false;
              if (addBtnLabel) addBtnLabel.textContent = 'Læg alle i kurven (' + currentCartItems.length + ')';
              feedbackEl.innerHTML = '<p class="mb__result-add-notice" style="color:#c0392b;">' + err.message + '</p>';
            });
          });
        }
      });
    }

    function goToStep(step) {
      currentStep = step;
      if (step === 2) buildAreaList();
      if (step === 3) renderResults();

      container.querySelectorAll('.mb__panel').forEach(function(p) { p.style.display = p.dataset.panel == step ? '' : 'none'; });

      stepEls.forEach(function(el) {
        var s = parseInt(el.dataset.step);
        el.classList.remove('mb__step--active', 'mb__step--done');
        if (s === step) el.classList.add('mb__step--active');
        else if (s < step) el.classList.add('mb__step--done');
      });

      ctaBar.style.display = step === 1 ? '' : 'none';
      container.dataset.step = step;
      container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function resetAll() {
      checkboxes.forEach(function(cb) { cb.checked = false; });
      areaValues = {};
      updateCta();
      goToStep(1);
    }

    checkboxes.forEach(function(cb) { cb.addEventListener('change', updateCta); });
    var loader = container.querySelector('#beregner-loader');
    function showLoader() {
      if (!loader) return;
      loader.dataset.active = 'true';
      loader.setAttribute('aria-hidden', 'false');
    }
    function hideLoader() {
      if (!loader) return;
      loader.dataset.active = 'false';
      loader.setAttribute('aria-hidden', 'true');
    }

    nextBtn.addEventListener('click', function() { if (!this.disabled) goToStep(2); });
    backBtn1.addEventListener('click', function() { goToStep(1); });
    nextBtn2.addEventListener('click', function() {
      if (this.disabled) return;
      showLoader();
      // Artificial delay so the user feels the system is computing something.
      setTimeout(function() {
        goToStep(3);
        // Small grace so the overlay fades after the new panel is painted.
        setTimeout(hideLoader, 120);
      }, 1200);
    });
    backBtn2.addEventListener('click', function() { goToStep(2); });
    restartBtn.addEventListener('click', resetAll);

    stepEls.forEach(function(el) {
      el.addEventListener('click', function() {
        var s = parseInt(this.dataset.step);
        if (this.classList.contains('mb__step--done')) goToStep(s);
      });
    });
  })();
</script>

