{%- liquid
  assign current_step = 1
-%}

{% render 'beregner-config' %}

<div class="mb" id="maler-beregner" data-step="{{ current_step }}">

  <!-- Page Header -->
  <div class="mb__header">
    <span class="mb__eyebrow">Malerberegner</span>
    <h1 class="mb__title">Beregn dit<br>malerforbrug</h1>
    <p class="mb__subtitle">Vælg behandling, angiv areal og få en præcis materialeliste klar til indkøb.</p>
  </div>

  <!-- Step Indicator -->
  <div class="mb__steps">
    <div class="mb__step mb__step--active" data-step="1">
      <span class="mb__step-circle">1</span>
      <span class="mb__step-label">Behandling</span>
    </div>
    <div class="mb__step" data-step="2">
      <span class="mb__step-circle">2</span>
      <span class="mb__step-label">Areal</span>
    </div>
    <div class="mb__step" data-step="3">
      <span class="mb__step-circle">3</span>
      <span class="mb__step-label">Resultat</span>
    </div>
  </div>

  <!-- Step 1: Vælg behandling -->
  <div class="mb__panel" data-panel="1">

    <!-- Indvendigt -->
    <div class="mb__section">
      <div class="mb__section-header">
        <h2 class="mb__section-title">Indvendigt</h2>
        <span class="mb__section-line"></span>
        <span class="mb__section-count">9 typer</span>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Væg</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="ny-gips-vaeg" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="4" y1="12" x2="20" y2="12"/></svg></span>
              <span class="mb__card-text">Ny gips – væg</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="tidligere-malet-gips-vaeg" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="12" y1="2" x2="12" y2="22"/><path d="M7 6v4M16 7v5"/></svg></span>
              <span class="mb__card-text">Tidligere malet gips – væg</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="vaev-filt-gips-beton" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7c4 0 4 4 8 4s4-4 8-4"/><path d="M2 13c4 0 4 4 8 4s4-4 8-4"/><path d="M2 19c4 0 4 4 8 4s4-4 8-4"/></svg></span>
              <span class="mb__card-text">Væv / filt – gips/beton</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="beton-mur-indvendigt" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="1"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="2" y1="16" x2="22" y2="16"/><line x1="12" y1="4" x2="12" y2="10"/><line x1="7" y1="10" x2="7" y2="16"/><line x1="17" y1="10" x2="17" y2="16"/></svg></span>
              <span class="mb__card-text">Beton / mur – indvendigt</span>
            </span>
          </label>
        </div>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Loft</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="nyt-gipsloft" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8h20"/><path d="M5 8L3 20h18l-2-12"/><path d="M9 8V5h6v3"/></svg></span>
              <span class="mb__card-text">Nyt gipsloft</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="tidligere-malet-loft" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8h20"/><path d="M5 8L3 20h18l-2-12"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="8" y1="16" x2="16" y2="16"/></svg></span>
              <span class="mb__card-text">Tidligere malet loft</span>
            </span>
          </label>
        </div>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Træværk</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="trae-indvendigt" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="14" x2="21" y2="14"/><circle cx="12" cy="11" r="2"/></svg></span>
              <span class="mb__card-text">Træ – indvendigt</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="koekkenlaager-inventar" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="9" y1="10" x2="9" y2="14"/><line x1="15" y1="10" x2="15" y2="14"/></svg></span>
              <span class="mb__card-text">Køkkenlåger & inventar</span>
            </span>
          </label>
        </div>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Metal</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="metal-indvendigt" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="7.5" cy="7.5" r="1.5"/><circle cx="16.5" cy="7.5" r="1.5"/><circle cx="7.5" cy="16.5" r="1.5"/><circle cx="16.5" cy="16.5" r="1.5"/></svg></span>
              <span class="mb__card-text">Metal – indvendigt</span>
            </span>
          </label>
        </div>
      </div>
    </div>

    <!-- Udvendigt -->
    <div class="mb__section">
      <div class="mb__section-header">
        <h2 class="mb__section-title">Udvendigt</h2>
        <span class="mb__section-line"></span>
        <span class="mb__section-count">5 typer</span>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Facade</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="facade-ny-afrenset" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-8 9 8"/><path d="M5 12v8h14v-8"/><rect x="10" y="14" width="4" height="6"/></svg></span>
              <span class="mb__card-text">Facade – ny/afrenset</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="facade-tidligere-malet" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-8 9 8"/><path d="M5 12v8h14v-8"/><rect x="10" y="14" width="4" height="6"/><path d="M8 14v3"/></svg></span>
              <span class="mb__card-text">Facade – tidligere malet</span>
            </span>
          </label>
        </div>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Træværk</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="udvendigt-trae" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="4" x2="5" y2="20"/><line x1="10" y1="3" x2="10" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/><line x1="20" y1="3" x2="20" y2="20"/><line x1="3" y1="10" x2="22" y2="10"/><line x1="3" y1="16" x2="22" y2="16"/></svg></span>
              <span class="mb__card-text">Udvendigt træ</span>
            </span>
          </label>
        </div>
      </div>

      <div class="mb__subgroup">
        <h3 class="mb__subgroup-title">Gulve</h3>
        <div class="mb__grid">
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="betongulv-bolig" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="20" height="12" rx="1"/><line x1="12" y1="8" x2="12" y2="20"/><line x1="2" y1="14" x2="22" y2="14"/></svg></span>
              <span class="mb__card-text">Betongulv – bolig</span>
            </span>
          </label>
          <label class="mb__card">
            <input type="checkbox" name="treatment" value="betongulv-industri-vaerksted" class="mb__checkbox">
            <span class="mb__card-inner">
              <span class="mb__card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="8" width="20" height="12" rx="1"/><line x1="8" y1="8" x2="8" y2="20"/><line x1="16" y1="8" x2="16" y2="20"/><line x1="2" y1="14" x2="22" y2="14"/></svg></span>
              <span class="mb__card-text">Betongulv – industri / værksted</span>
            </span>
          </label>
        </div>
      </div>
    </div>

    <!-- Help Strip -->
    <div class="mb__help">
      <div class="mb__help-left">
        <h3 class="mb__help-title">Ikke sikker på hvilken behandling?</h3>
        <p class="mb__help-text">Vi hjælper dig med at finde den rigtige løsning til dit projekt.</p>
      </div>
      <a href="/pages/contact" class="mb__help-btn">Kontakt os</a>
    </div>
  </div>

  <!-- Step 2: Areal & valg -->
  <div class="mb__panel" data-panel="2" style="display:none;">
    <p class="mb__description">Angiv hvor mange kvadratmeter du skal male for hver valgt behandling.</p>
    <div class="mb__area-list" id="beregner-area-list"></div>
    <div class="mb__nav mb__nav--between">
      <button class="mb__btn mb__btn--back" id="beregner-back-1">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Tilbage
      </button>
      <button class="mb__btn mb__btn--next" id="beregner-next-2" disabled>
        Næste: Resultat
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>

  <!-- Loading overlay (shown briefly between Areal → Resultat) -->
  <div class="mb__loader" id="beregner-loader" aria-hidden="true">
    <div class="mb__loader-inner">
      <span class="mb__loader-spinner" aria-hidden="true"></span>
      <span class="mb__loader-label">Beregner dit materialebehov…</span>
    </div>
  </div>

  <!-- Step 3: Resultat -->
  <div class="mb__panel" data-panel="3" style="display:none;">
    <p class="mb__description">Her er din materialeberegning baseret på de valgte behandlinger og arealer.</p>
    <div class="mb__results" id="beregner-results"></div>
    <div class="mb__nav mb__nav--between">
      <button class="mb__btn mb__btn--back" id="beregner-back-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Tilbage
      </button>
      <button class="mb__btn mb__btn--next" id="beregner-restart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
        Start forfra
      </button>
    </div>
  </div>

  <!-- Fixed CTA Bar -->
  <div class="mb__cta-bar" id="beregner-cta-bar">
    <span class="mb__cta-hint" id="beregner-cta-hint">Vælg mindst én behandling</span>
    <button class="mb__btn mb__btn--next" id="beregner-next" disabled>
      Næste
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</div>

<style>
  .mb {
    --cream: #F9F6F0;
    --warm-white: #FDFBF8;
    --forest: #1C1917;
    --forest-light: #2E2B28;
    --forest-faint: #F0EAE2;
    --gold: #B5422E;
    --gold-light: #EDE8E0;
    --charcoal: #1C1917;
    --mid: #8A8078;
    --border: #DDD8CF;
    --border-soft: #EAE6DF;

    max-width: 960px;
    margin: 0 auto;
    padding: 56px 24px 120px;
    font-family: var(--font-body--family);
    color: var(--charcoal);
    box-sizing: border-box;
  }

  .mb *, .mb *::before, .mb *::after { box-sizing: border-box; }

  /* ── Page Header ── */
  .mb__header { margin-bottom: 48px; }

  .mb__eyebrow {
    display: block;
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .mb__title {
    font-family: var(--font-primary--family);
    font-size: 52px;
    font-weight: 500;
    color: var(--charcoal);
    letter-spacing: -0.01em;
    line-height: 1.05;
    margin: 0 0 16px;
  }

  .mb__subtitle {
    font-family: var(--font-body--family);
    font-size: 1.2rem;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.65;
    max-width: 480px;
    margin: 0;
  }

  /* ── Step Indicator ── */
  .mb__steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 80px;
    margin-bottom: 48px;
    position: relative;
    padding: 0 40px;
  }

  .mb__steps::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 80px;
    right: 80px;
    height: 1px;
    background: var(--border);
  }

  .mb__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    position: relative;
    z-index: 1;
    cursor: default;
  }

  .mb__step-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 500;
    background: var(--cream);
    border: 1.5px solid var(--border);
    color: var(--mid);
    transition: all 0.3s ease;
  }

  .mb__step-label {
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mid);
    transition: color 0.3s ease;
  }

  .mb__step--active .mb__step-circle {
    background: var(--forest);
    border-color: var(--forest);
    color: #fff;
    box-shadow: 0 0 0 5px rgba(28, 25, 23, 0.10);
  }

  .mb__step--active .mb__step-label { color: var(--charcoal); }

  .mb__step--done .mb__step-circle {
    background: var(--forest-faint);
    border-color: var(--forest-light);
    color: var(--forest);
  }

  .mb__step--done .mb__step-label { color: var(--forest); }
  .mb__step--done { cursor: pointer; }

  /* ── Section Labels ── */
  .mb__section { margin-top: 40px; }

  .mb__section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .mb__section-title {
    font-family: var(--font-primary--family);
    font-size: 22px;
    font-weight: 500;
    font-style: italic;
    color: var(--charcoal);
    margin: 0;
    white-space: nowrap;
  }

  .mb__section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .mb__section-count {
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3px 10px;
    white-space: nowrap;
  }

  /* ── Card Grid ── */
  .mb__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  /* Artificial loading overlay shown briefly between Areal and Resultat. */
  .mb__loader {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 9999;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .mb__loader[data-active="true"] {
    display: flex;
    opacity: 1;
  }

  .mb__loader-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .mb__loader-spinner {
    display: block;
    width: 42px;
    height: 42px;
    border: 2px solid rgba(0, 0, 0, 0.08);
    border-top-color: var(--charcoal, #111);
    border-radius: 50%;
    animation: mb-loader-spin 0.9s linear infinite;
  }

  .mb__loader-label {
    font-family: var(--font-body--family);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--charcoal, #111);
  }

  @keyframes mb-loader-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mb__loader-spinner { animation-duration: 2s; }
  }

  .mb__subgroup + .mb__subgroup {
    margin-top: 24px;
  }

  .mb__subgroup-title {
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--mid);
    margin: 0 0 10px;
  }

  /* ── Treatment Card ── */
  .mb__card {
    position: relative;
    cursor: pointer;
    display: flex;
  }

  .mb__checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .mb__card-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 18px 16px 16px;
    background: var(--warm-white);
    border: 1.5px solid var(--border-soft);
    border-radius: 10px;
    width: 100%;
    position: relative;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .mb__card-inner::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--forest);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .mb__card-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--cream);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .mb__card-icon svg {
    width: 18px;
    height: 18px;
    stroke: var(--forest);
    transition: stroke 0.2s ease;
  }

  .mb__card-text {
    font-family: var(--font-body--family);
    font-size: 15px;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1.4;
  }

  /* Card hover */
  .mb__card-inner:hover {
    border-color: var(--forest);
    background: var(--forest-faint);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(44, 74, 62, 0.10);
  }

  .mb__card-inner:hover::before { transform: scaleX(1); }

