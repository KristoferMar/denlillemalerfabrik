<script>
  (function() {
    const container = document.getElementById('maler-beregner');
    if (!container) return;

    // Load config
    var config = {};
    try {
      config = JSON.parse(document.getElementById('beregner-config').textContent);
    } catch(e) {
      console.error('Beregner config parse error', e);
    }

    const checkboxes = container.querySelectorAll('.maler-beregner__checkbox');
    const nextBtn = container.querySelector('#beregner-next');
    const nextBtn2 = container.querySelector('#beregner-next-2');
    const backBtn1 = container.querySelector('#beregner-back-1');
    const backBtn2 = container.querySelector('#beregner-back-2');
    const restartBtn = container.querySelector('#beregner-restart');
    const stepBtns = container.querySelectorAll('.maler-beregner__step-btn');
    const stepCurrent = container.querySelector('.maler-beregner__step-current');
    const stepLabel = container.querySelector('.maler-beregner__step-label');
    const areaList = container.querySelector('#beregner-area-list');
    const resultsContainer = container.querySelector('#beregner-results');

    const stepLabels = {
      1: 'Vælg behandling',
      2: 'Areal & valg',
      3: 'Resultat'
    };

    // SVG icons for categories
    const iconIndvendigt = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>';
    const iconUdvendigt = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>';

    // Store area values so they persist when navigating back
    var areaValues = {};

    function getSelectedTreatments() {
      return Array.from(checkboxes)
        .filter(function(cb) { return cb.checked; })
        .map(function(cb) { return cb.value; });
    }

    function updateNextButton() {
      nextBtn.disabled = getSelectedTreatments().length === 0;
    }

    function updateNextButton2() {
      var inputs = areaList.querySelectorAll('.maler-beregner__area-input');
      var allFilled = Array.from(inputs).every(function(input) { return parseFloat(input.value) > 0; });
      nextBtn2.disabled = !allFilled;
    }

    function buildAreaList() {
      var selected = getSelectedTreatments();
      areaList.innerHTML = '';

      selected.forEach(function(value) {
        var t = config.treatments && config.treatments[value];
        var name = t ? t.name : value;
        var cat = t ? (t.category === 'udvendigt' ? 'Udvendigt' : 'Indvendigt') : '';
        var icon = cat === 'Udvendigt' ? iconUdvendigt : iconIndvendigt;
        var savedValue = areaValues[value] || '';

        var card = document.createElement('div');
        card.className = 'maler-beregner__area-card';
        card.innerHTML =
          '<div class="maler-beregner__area-card-info">' +
            '<div class="maler-beregner__area-card-icon">' + icon + '</div>' +
            '<div class="maler-beregner__area-card-text">' +
              '<span class="maler-beregner__area-card-title">' + name + '</span>' +
              '<span class="maler-beregner__area-card-tag">' + cat + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="maler-beregner__area-input-wrap">' +
            '<input type="number" class="maler-beregner__area-input" data-treatment="' + value + '" placeholder="0" min="0" step="0.5" value="' + savedValue + '">' +
            '<span class="maler-beregner__area-unit">m²</span>' +
          '</div>';

        areaList.appendChild(card);
      });

      areaList.querySelectorAll('.maler-beregner__area-input').forEach(function(input) {
        input.addEventListener('input', function() {
          areaValues[this.dataset.treatment] = this.value;
          updateNextButton2();
        });
      });

      updateNextButton2();
    }

    // --- Product data cache & fetcher ---
    var productCache = {};

    function fetchProduct(handle) {
      if (productCache[handle]) return productCache[handle];
      if (!handle || handle.indexOf('TODO') === 0) {
        productCache[handle] = Promise.resolve(null);
        return productCache[handle];
      }
      productCache[handle] = fetch('/products/' + handle + '.json')
        .then(function(res) { return res.ok ? res.json() : null; })
        .then(function(data) { return data && data.product ? data.product : null; })
        .catch(function() { return null; });
      return productCache[handle];
    }

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2).replace('.', ',');
      return amount + ' kr.';
    }

    // --- Step 3: Calculate & render results ---
    function calculateResults() {
      var selected = getSelectedTreatments();
      var results = [];

      selected.forEach(function(treatmentKey) {
        var t = config.treatments && config.treatments[treatmentKey];
        if (!t) return;

        var area = parseFloat(areaValues[treatmentKey]) || 0;
        var coats = t.coats || 2;
        var products = t.products || {};
        var items = [];

        Object.keys(products).forEach(function(key) {
          var p = products[key];
          var qty = 0;

          if (p.per_m2 > 0) {
            // liters needed = area * per_m2 * coats
            qty = Math.ceil(area * p.per_m2 * coats * 10) / 10;
          } else {
            qty = p.flat_qty || 1;
          }

          items.push({
            label: p.label,
            handle: p.handle,
            role: p.role,
            qty: qty,
            unit: p.per_m2 > 0 ? 'L' : 'stk',
            isTodo: p.handle.indexOf('TODO') === 0
          });
        });

        results.push({
          name: t.name,
          category: t.category === 'udvendigt' ? 'Udvendigt' : 'Indvendigt',
          area: area,
          coats: coats,
          coverage: t.coverage_m2_per_liter,
          items: items
        });
      });

      return results;
    }

    function renderResults() {
      var results = calculateResults();
      resultsContainer.innerHTML = '<div class="maler-beregner__result-loading">Henter produktdata...</div>';

      // Collect all unique handles to fetch
      var allHandles = [];
      results.forEach(function(group) {
        group.items.forEach(function(item) {
          if (allHandles.indexOf(item.handle) === -1) {
            allHandles.push(item.handle);
          }
        });
      });

      // Fetch all products in parallel
      Promise.all(allHandles.map(fetchProduct)).then(function(products) {
        // Build lookup: handle -> product data
        var productMap = {};
        allHandles.forEach(function(handle, i) {
          productMap[handle] = products[i];
        });

        resultsContainer.innerHTML = '';
        var totalArea = 0;
        var hasTodo = false;

        var roleLabels = {
          primer: 'Primer',
          paint: 'Maling',
          tool: 'Værktøj',
          accessory: 'Tilbehør'
        };

        results.forEach(function(group) {
          totalArea += group.area;

          var html =
            '<div class="maler-beregner__result-group">' +
              '<div class="maler-beregner__result-group-header">' +
                '<span class="maler-beregner__result-group-title">' + group.name + '</span>' +
                '<span class="maler-beregner__result-group-area">' + group.area + ' m² &middot; ' + group.coats + ' lag &middot; ' + group.coverage + ' m²/L</span>' +
              '</div>' +
              '<table class="maler-beregner__result-table">' +
                '<thead><tr>' +
                  '<th>Produkt</th>' +
                  '<th>Type</th>' +
                  '<th>Mængde</th>' +
                '</tr></thead>' +
                '<tbody>';

          group.items.forEach(function(item) {
            var shopProduct = productMap[item.handle];
            var productCell = '';

            if (shopProduct) {
              // Real product found — show image, title, price
              var imgSrc = shopProduct.image ? shopProduct.image.src.replace(/\.([a-z]+)$/, '_100x100.$1') : '';
              var imgTag = imgSrc
                ? '<img class="maler-beregner__result-product-img" src="' + imgSrc + '" alt="' + shopProduct.title + '" loading="lazy">'
                : '<div class="maler-beregner__result-product-placeholder"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>';
              var price = shopProduct.variants && shopProduct.variants[0] ? formatMoney(parseInt(shopProduct.variants[0].price * 100)) : '';
              productCell =
                '<div class="maler-beregner__result-product">' +
                  imgTag +
                  '<div class="maler-beregner__result-product-info">' +
                    '<span class="maler-beregner__result-product-title"><a href="/products/' + item.handle + '">' + shopProduct.title + '</a></span>' +
                    (price ? '<span class="maler-beregner__result-product-price">' + price + '</span>' : '') +
                  '</div>' +
                '</div>';
            } else {
              // TODO or missing product
              hasTodo = true;
              productCell =
                '<div class="maler-beregner__result-product">' +
                  '<div class="maler-beregner__result-product-placeholder"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div>' +
                  '<div class="maler-beregner__result-product-info">' +
                    '<span class="maler-beregner__result-product-title">' + item.label + '</span>' +
                    '<span class="maler-beregner__result-todo">(produkt mangler)</span>' +
                  '</div>' +
                '</div>';
            }

            html +=
              '<tr>' +
                '<td>' + productCell + '</td>' +
                '<td><span class="maler-beregner__result-role maler-beregner__result-role--' + item.role + '">' + (roleLabels[item.role] || item.role) + '</span></td>' +
                '<td><span class="maler-beregner__result-qty">' + item.qty + ' ' + item.unit + '</span></td>' +
              '</tr>';
          });

          html += '</tbody></table></div>';
          resultsContainer.innerHTML += html;
        });

        // Collect cart items (variant id + quantity) for add-to-cart
        var cartItems = [];
        results.forEach(function(group) {
          group.items.forEach(function(item) {
            var shopProduct = productMap[item.handle];
            if (shopProduct && shopProduct.variants && shopProduct.variants[0]) {
              // Merge quantities if same variant appears across treatments
              var variantId = shopProduct.variants[0].id;
              var existing = cartItems.find(function(ci) { return ci.id === variantId; });
              if (existing) {
                existing.quantity += Math.ceil(item.qty);
              } else {
                cartItems.push({
                  id: variantId,
                  quantity: Math.ceil(item.qty)
                });
              }
            }
          });
        });

        // Add-to-cart button
        var addBtnHtml = '';
        if (cartItems.length > 0) {
          addBtnHtml =
            '<button class="maler-beregner__result-add-all" id="beregner-add-to-cart">' +
              '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>' +
              'Læg alle produkter i indkøbskurv (' + cartItems.length + ')' +
            '</button>' +
            (hasTodo ? '<p class="maler-beregner__result-add-notice">Produkter markeret med "(produkt mangler)" tilføjes ikke.</p>' : '') +
            '<div id="beregner-cart-feedback"></div>';
        }

        // Summary
        var summaryHtml =
          '<div class="maler-beregner__result-summary">' +
            '<p class="maler-beregner__result-summary-title">Samlet areal: ' + totalArea + ' m²</p>' +
            '<p class="maler-beregner__result-summary-text">' +
              'Beregningen er et estimat baseret på standardforbrug. Det faktiske forbrug kan variere afhængigt af underlag, sugning og påføringsmetode.' +
              (hasTodo ? ' Produkter markeret med "(produkt mangler)" er endnu ikke tilgængelige i shoppen.' : '') +
            '</p>' +
          '</div>';

        resultsContainer.innerHTML += addBtnHtml + summaryHtml;

        // Bind add-to-cart button
        var addBtn = document.getElementById('beregner-add-to-cart');
        var feedbackEl = document.getElementById('beregner-cart-feedback');
        if (addBtn) {
          addBtn.addEventListener('click', function() {
            addBtn.disabled = true;
            addBtn.textContent = 'Tilføjer...';

            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ items: cartItems })
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
              if (data.status && data.status === 422) {
                throw new Error(data.description || 'Kunne ikke tilføje til kurven');
              }
              feedbackEl.innerHTML =
                '<div class="maler-beregner__result-add-success">' +
                  '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>' +
                  'Produkterne er tilføjet! <a href="/cart">Gå til indkøbskurv</a>' +
                '</div>';
              addBtn.style.display = 'none';

              // Update cart icon count if theme supports it
              fetch('/cart.js')
                .then(function(r) { return r.json(); })
                .then(function(cart) {
                  var countEls = document.querySelectorAll('.cart-count, [data-cart-count], .header__cart-count');
                  countEls.forEach(function(el) { el.textContent = cart.item_count; });
                  // Dispatch event for themes that listen
                  document.dispatchEvent(new CustomEvent('cart:refresh'));
                });
            })
            .catch(function(err) {
              addBtn.disabled = false;
              addBtn.innerHTML =
                '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>' +
                'Læg alle produkter i indkøbskurv (' + cartItems.length + ')';
              feedbackEl.innerHTML = '<p class="maler-beregner__result-add-notice" style="color:#e74c3c;">' + err.message + '</p>';
            });
          });
        }
      });
    }

    // --- Navigation ---
    function goToStep(step) {
      if (step === 2) buildAreaList();
      if (step === 3) renderResults();

      container.querySelectorAll('.maler-beregner__panel').forEach(function(panel) {
        panel.style.display = panel.dataset.panel == step ? '' : 'none';
      });

      stepBtns.forEach(function(btn) {
        var btnStep = parseInt(btn.dataset.step);
        btn.classList.toggle('maler-beregner__step-btn--active', btnStep === step);
        btn.classList.toggle('maler-beregner__step-btn--completed', btnStep < step);
        btn.disabled = btnStep > step;
      });

      stepCurrent.textContent = step;
      stepLabel.textContent = stepLabels[step];
      container.dataset.step = step;
      container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function resetAll() {
      checkboxes.forEach(function(cb) { cb.checked = false; });
      areaValues = {};
      updateNextButton();
      goToStep(1);
    }

    // Event listeners
    checkboxes.forEach(function(cb) {
      cb.addEventListener('change', updateNextButton);
    });

    nextBtn.addEventListener('click', function() {
      if (!this.disabled) goToStep(2);
    });

    backBtn1.addEventListener('click', function() { goToStep(1); });

    nextBtn2.addEventListener('click', function() {
      if (!this.disabled) goToStep(3);
    });

    backBtn2.addEventListener('click', function() { goToStep(2); });

    restartBtn.addEventListener('click', resetAll);

    stepBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!this.disabled) goToStep(parseInt(this.dataset.step));
      });
    });
  })();
</script>

