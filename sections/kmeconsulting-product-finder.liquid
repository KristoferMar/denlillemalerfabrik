{%- liquid
  assign colors = shop.metaobjects['paint_color'].values
  assign types = shop.metaobjects['paint_type'].values
  assign collection = section.settings.collection
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  id="product-finder"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="product-finder">
    {%- if section.settings.heading != blank -%}
      <h2 class="product-finder__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="product-finder__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <!-- Step indicators -->
    <div class="product-finder__indicators">
      <div class="product-finder__step-indicator product-finder__step-indicator--active" data-step="1">
        <span class="product-finder__step-number">1</span>
        <span class="product-finder__step-label">Farve</span>
      </div>
      <div class="product-finder__step-divider"></div>
      <div class="product-finder__step-indicator" data-step="2">
        <span class="product-finder__step-number">2</span>
        <span class="product-finder__step-label">Overflade</span>
      </div>
      <div class="product-finder__step-divider"></div>
      <div class="product-finder__step-indicator" data-step="3">
        <span class="product-finder__step-number">3</span>
        <span class="product-finder__step-label">Resultat</span>
      </div>
    </div>

    <!-- Step 1: Choose color -->
    <div class="product-finder__step" data-step="1">
      <h3 class="product-finder__step-heading">Vælg en farve</h3>
      <div class="product-finder__color-grid">
        {%- comment -%}
          Group colors by family and sort each family by dlm_code (lightest first).
          This makes each column represent a color family, going light→dark top→bottom.
        {%- endcomment -%}

        {%- comment -%} Step 1: Collect unique families {%- endcomment -%}
        {%- assign family_list = '' -%}
        {%- for color in colors -%}
          {%- assign fam = color.color_family.value | default: color.color_family -%}
          {%- unless family_list contains fam -%}
            {%- unless family_list == '' -%}{%- assign family_list = family_list | append: '|||' -%}{%- endunless -%}
            {%- assign family_list = family_list | append: fam -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- assign families = family_list | split: '|||' | sort -%}

        {%- comment -%} Step 2: Find the max number of colors in any family (= number of rows) {%- endcomment -%}
        {%- assign max_rows = 0 -%}
        {%- for fam in families -%}
          {%- assign fam_count = 0 -%}
          {%- for color in colors -%}
            {%- assign c_fam = color.color_family.value | default: color.color_family -%}
            {%- if c_fam == fam -%}
              {%- assign fam_count = fam_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if fam_count > max_rows -%}
            {%- assign max_rows = fam_count -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Step 3: For each family, collect and sort codes {%- endcomment -%}
        {%- comment -%} Output row by row: row 0 = lightest shade per family, row 1 = next, etc. {%- endcomment -%}
        {%- for row in (0..max_rows) -%}
          {%- if row >= max_rows -%}{%- break -%}{%- endif -%}
          {%- for fam in families -%}
            {%- comment -%} Collect sorted codes for this family {%- endcomment -%}
            {%- assign fam_codes = '' -%}
            {%- for color in colors -%}
              {%- assign c_fam = color.color_family.value | default: color.color_family -%}
              {%- if c_fam == fam -%}
                {%- assign c_code = color.dlm_code.value | default: color.dlm_code -%}
                {%- unless fam_codes == '' -%}{%- assign fam_codes = fam_codes | append: ',' -%}{%- endunless -%}
                {%- assign fam_codes = fam_codes | append: c_code -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign sorted_codes = fam_codes | split: ',' | sort -%}

            {%- if row < sorted_codes.size -%}
              {%- assign target_code = sorted_codes[row] -%}
              {%- for color in colors -%}
                {%- assign c_code = color.dlm_code.value | default: color.dlm_code -%}
                {%- if c_code == target_code -%}
                  <button
                    type="button"
                    class="product-finder__color-btn"
                    data-color-id="{{ color.dlm_code.value }}"
                    data-color-name="{{ color.name.value }}"
                    data-color-code="{{ color.dlm_code.value }}"
                    data-color-hex="{{ color.hex_color.value }}"
                    aria-label="{{ color.name.value }} ({{ color.dlm_code.value }})"
                  >
                    <span class="product-finder__color-swatch" style="background-color: {{ color.hex_color.value }};"></span>
                    <span class="product-finder__color-name">{{ color.name.value }}</span>
                    <span class="product-finder__color-code">{{ color.dlm_code.value }}</span>
                  </button>
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              <div class="product-finder__color-btn product-finder__color-btn--empty"></div>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Step 2: Choose surface type -->
    <div class="product-finder__step" data-step="2" hidden>
      <button type="button" class="product-finder__back-btn" data-back-to="1">← Tilbage til farver</button>
      <h3 class="product-finder__step-heading">Hvad skal males?</h3>
      <div class="product-finder__type-grid">
        {%- for type in types -%}
          <button
            type="button"
            class="product-finder__type-btn"
            data-type-id="{{ type.name.value }}"
            data-type-name="{{ type.name.value }}"
          >
            {%- render 'product-finder-type-icon', type_name: type.name.value -%}
            <span class="product-finder__type-name">{{ type.name.value }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    <!-- Step 3: Result -->
    <div class="product-finder__step" data-step="3" hidden>
      <button type="button" class="product-finder__back-btn" data-back-to="2">← Tilbage til overflader</button>
      <h3 class="product-finder__step-heading">Dit resultat</h3>
      <div class="product-finder__summary">
        <span class="product-finder__summary-item">
          <strong>Farve:</strong> <span id="pf-selected-color-name"></span>
        </span>
        <span class="product-finder__summary-item">
          <strong>Overflade:</strong> <span id="pf-selected-type-name"></span>
        </span>
      </div>
      <div id="product-finder-result"></div>
      <button type="button" class="product-finder__reset-btn" id="product-finder-reset">Start forfra</button>
    </div>
  </div>
</div>

<!--
  Variant lookup map for the finder. For each canonical paint-type product
  (one per paint-type × default glans), emit a row per Farve variant so the
  JS can resolve "color + paint-type" → a specific variant URL.

  Default glans per paint-type (hand-picked as the "most common" choice):
    Vægmaling → Glans 10 (only option)
    Loftmaling → Glans 5
    Træ & Metal → Glans 30 (most sold for træværk per malerbeskrivelser.md)
    Strukturmaling → the single consolidated product
    Træbeskyttelse → Glans 20 (halvmat, standard compromise)
    Gulvmaling → Glans 40 (standard-gulvmaling)
-->
<script id="product-finder-variant-map" type="application/json">
{
  "variants": [
    {%- comment -%}
      Hardcoded handle → paint-type name pairs. Names must match the paint_type
      metaobject values that the step-2 type buttons emit (their data-type-name).
      We don't read product.metafields.custom.paint_type because that metafield
      isn't currently populated on the restructured catalog.
    {%- endcomment -%}
    {%- assign finder_pairs = 'vaegmaling-glans-10|Vægmaling,loftmaling-glans-5|Loftmaling,trae-metal-glans-30|Træ & Metal,strukturmaling-glans-5|Strukturmaling,traebeskyttelse-glans-20|Træbeskyttelse,gulvmaling-glans-40|Gulvmaling' | split: ',' -%}
    {%- assign first = true -%}
    {%- for pair in finder_pairs -%}
      {%- assign parts = pair | split: '|' -%}
      {%- assign handle = parts[0] -%}
      {%- assign paint_type_name = parts[1] -%}
      {%- assign product = all_products[handle] -%}
      {%- if product.id == blank -%}{%- continue -%}{%- endif -%}

      {%- assign farve_position = 0 -%}
      {%- for option in product.options_with_values -%}
        {%- if option.name == 'Farve' -%}
          {%- assign farve_position = forloop.index -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if farve_position == 0 -%}{%- continue -%}{%- endif -%}

      {%- assign seen_colors = '' -%}
      {%- for variant in product.variants -%}
        {%- assign color_value = '' -%}
        {%- if farve_position == 1 -%}{%- assign color_value = variant.option1 -%}
        {%- elsif farve_position == 2 -%}{%- assign color_value = variant.option2 -%}
        {%- elsif farve_position == 3 -%}{%- assign color_value = variant.option3 -%}
        {%- endif -%}
        {%- if color_value == blank -%}{%- continue -%}{%- endif -%}
        {%- capture seen_key -%}|{{ color_value }}|{%- endcapture -%}
        {%- unless seen_colors contains seen_key -%}
          {%- unless first -%},{%- endunless -%}
          {%- assign first = false -%}
          {%- assign variant_image = variant.featured_image | default: product.featured_image -%}
    {
      "paint_type": {{ paint_type_name | json }},
      "color": {{ color_value | json }},
      "handle": {{ product.handle | json }},
      "variant_id": {{ variant.id | json }},
      "product_title": {{ product.title | json }},
      "image": {{ variant_image | image_url: width: 400 | json }},
      "price": {{ product.price | money | json }}
    }
          {%- assign seen_colors = seen_colors | append: seen_key -%}
        {%- endunless -%}
      {%- endfor -%}
    {%- endfor -%}
  ]
}
</script>

<style>
  .product-finder {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .product-finder__heading {
    text-align: center;
    margin: 0;
  }

  .product-finder__subheading {
    text-align: center;
    margin: 0;
    opacity: 0.7;
    font-size: 1.2rem;
  }

  /* Step indicators */
  .product-finder__indicators {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .product-finder__step-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    opacity: 0.35;
    transition: opacity 0.3s ease;
  }

  .product-finder__step-indicator--active {
    opacity: 1;
  }

  .product-finder__step-indicator--completed {
    opacity: 0.6;
  }

  .product-finder__step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    font-size: 1rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .product-finder__step-indicator--active .product-finder__step-number {
    background-color: var(--color-foreground, #000);
    color: var(--color-background, #fff);
  }

  .product-finder__step-indicator--completed .product-finder__step-number {
    background-color: var(--color-foreground, #000);
    color: var(--color-background, #fff);
  }

  .product-finder__step-label {
    font-size: 1.05rem;
    font-weight: 500;
  }

  .product-finder__step-divider {
    width: 48px;
    height: 1.5px;
    background-color: currentColor;
    opacity: 0.2;
  }

  /* Step fade animations */
  @keyframes product-finder-fade-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-12px);
    }
  }

  @keyframes product-finder-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-finder__step--fade-out {
    animation: product-finder-fade-out 0.25s ease forwards;
  }

  .product-finder__step--fade-in {
    animation: product-finder-fade-in 0.3s ease forwards;
  }

  /* Step headings */
  .product-finder__step-heading {
    text-align: center;
    margin: 0 0 16px;
    font-size: 1.2rem;
  }

  /* Back button */
  .product-finder__back-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    font-size: 0.875rem;
    padding: 0;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .product-finder__back-btn:hover {
    opacity: 1;
  }

  /* Color grid */
  .product-finder__color-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  @media screen and (min-width: 750px) {
    .product-finder__color-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 12px;
    }
  }

  @media screen and (min-width: 990px) {
    .product-finder__color-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }

  .product-finder__color-swatch {
    display: block;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.12);
    flex-shrink: 0;
  }

  .product-finder__color-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 12px;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    border-radius: 10px;
    background: #ffffff;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
    color: inherit;
  }

  .product-finder__color-btn:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    transform: scale(1.02);
  }

  .product-finder__color-btn--empty {
    visibility: hidden;
    pointer-events: none;
    border: none;
  }

  .product-finder__color-name {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .product-finder__color-code {
    font-size: 0.75rem;
    opacity: 0.5;
    font-family: monospace;
  }

  /* Type grid */
  .product-finder__type-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  @media screen and (min-width: 750px) {
    .product-finder__type-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .product-finder__type-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .product-finder__type-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 32px 24px;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    border-radius: 8px;
    background: #ffffff;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
    color: inherit;
  }

  .product-finder__type-btn:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    transform: scale(1.02);
  }

  .product-finder__type-name {
    font-size: 1.15rem;
    font-weight: 500;
  }

  /* Summary */
  .product-finder__summary {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
    padding: 16px;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .product-finder__summary-item {
    font-size: 0.9rem;
  }

  /* Result: product cards */
  .product-finder__products {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media screen and (min-width: 750px) {
    .product-finder__products {
      grid-template-columns: repeat(2, 1fr);
    }

    .product-finder__products--single {
      grid-template-columns: 1fr;
      max-width: 380px;
      margin: 0 auto;
    }
  }

  .product-finder__product-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .product-finder__product-card:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    transform: scale(1.02);
  }

  .product-finder__product-image {
    width: 100%;
    object-fit: contain;
    padding: 20px;
    background-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.03);
  }

  .product-finder__product-image--placeholder {
    background-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.05);
  }

  .product-finder__product-info {
    padding: 16px 20px 6px;
  }

  .product-finder__product-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .product-finder__product-price {
    margin: 4px 0 0;
    opacity: 0.7;
    font-size: 0.9rem;
  }

  .product-finder__product-cta {
    display: block;
    padding: 10px 20px 16px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* Loading bar */
  .product-finder__loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 48px 16px;
  }

  .product-finder__loader-text {
    font-size: 0.9rem;
    opacity: 0.6;
  }

  .product-finder__loader-track {
    width: 100%;
    max-width: 320px;
    height: 4px;
    background-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .product-finder__loader-bar {
    height: 100%;
    width: 0;
    background-color: var(--color-foreground, #000);
    border-radius: 4px;
    animation: product-finder-load 1.2s ease forwards;
  }

  @keyframes product-finder-load {
    0% { width: 0; }
    40% { width: 60%; }
    80% { width: 90%; }
    100% { width: 100%; }
  }

  /* No result */
  .product-finder__no-result {
    text-align: center;
    padding: 32px 16px;
    opacity: 0.7;
  }

  .product-finder__no-result p {
    margin: 4px 0;
  }

  /* Reset button */
  .product-finder__reset-btn {
    width: 100%;
    margin-top: 1rem;
    background: none;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.2);
    border-radius: 8px;
    padding: 12px 32px;
    cursor: pointer;
    font-size: 0.9rem;
    color: inherit;
    transition: border-color 0.2s ease;
  }

  .product-finder__reset-btn:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.5);
  }
</style>

{{ 'kmeconsulting-product-finder.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Produktfinder",
  "class": "kmeconsulting-product-finder",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Find din maling"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Vælg farve og overflade, så finder vi det rigtige produkt til dig."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion",
      "info": "Vælg den kollektion produktfinderen skal søge i. Lad stå tom for at søge i alle produkter."
    },
    {
      "type": "header",
      "content": "Sektionslayout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        {
          "value": "page-width",
          "label": "Sidebredde"
        },
        {
          "value": "full-width",
          "label": "Fuld bredde"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Produktfinder",
      "category": "Farver"
    }
  ]
}
{% endschema %}
