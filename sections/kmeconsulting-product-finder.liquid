{%- comment -%}
  Paint color data comes from `snippets/paint-colors-data.liquid` (auto-generated
  from docs/colors/dlm-colors-with-ncs.json by scripts/sync-colors-to-shopify.mjs).
  That snippet defines 8 family arrays: whites_arr, blues_arr, greys_arr,
  greens_arr, neutral_arr, yellow_arr, pink_arr, red_arr. Each entry is encoded
  as `<dlm_id>|<name_da>|<display_hex>`.

  We DON'T read from `shop.metaobjects['paint_color']` or `shop.metafields.custom.paint_palette.value`
  here because Shopify Liquid caps both at 50 iterations regardless of `limit:`,
  which silently truncates the 200-color palette to Whites + Blues only.
  See: https://shopify.dev/docs/api/liquid/objects/metafield#metafield-value
  and the project memory file project_dlm_paint_colors.md.
{%- endcomment -%}
{%- include 'paint-colors-data' -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  id="product-finder"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="vores-farver">
    <div class="vores-farver__header">
      <span class="vores-farver__eyebrow">VORES FARVER · 200 NUANCER</span>
      {%- if section.settings.heading != blank -%}
        <h2 class="vores-farver__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="vores-farver__lead">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="vores-farver__hint">
        <span class="vores-farver__hint-dot" aria-hidden="true"></span>
        <span>Prøv det: hold musen hen over en farve</span>
      </div>
    </div>

    {%- comment -%}
      Render the 200 colors as an 8-column × 25-row grid grouped by family.
      Each column = a color family, sorted top → bottom from lightest to darkest
      by DLM code (so rows 0–3 are the 4 original anchor shades, rows 4–24 are
      the 21 tonal expansions added 2026-05-12).

      `families` is the English identifier used for matching the metaobject
      `color_family` field (source of truth: docs/colors/dlm-colors-with-ncs.json).
      `family_labels` is the user-facing Danish label rendered in the filter pills.
      Order is curated to match the Farvekatalog page (page.catalogue.json).
    {%- endcomment -%}

    {%- assign families = 'Whites,Blues,Greys,Greens,Warm Neutrals,Yellows / Sands,Pinks / Coppers,Reds / Browns' | split: ',' -%}
    {%- assign family_labels = 'Hvid,Blå,Grå,Grøn,Varm Neutral,Gul,Rosa,Rød' | split: ',' -%}

    <div class="vores-farver__filters" role="tablist" aria-label="Filtrér efter farvefamilie">
      <button
        type="button"
        class="vores-farver__filter vores-farver__filter--active"
        data-family-filter="all"
      >
        Alle
      </button>
      {%- for fam in families -%}
        {%- assign fam_label = family_labels[forloop.index0] -%}
        {%- assign fam_accent = '#888' -%}
        {%- case fam -%}
          {%- when 'Whites' -%}{%- assign fam_accent = '#F5F0EB' -%}
          {%- when 'Blues' -%}{%- assign fam_accent = '#A3C1CE' -%}
          {%- when 'Greys' -%}{%- assign fam_accent = '#908D86' -%}
          {%- when 'Greens' -%}{%- assign fam_accent = '#A3B5A0' -%}
          {%- when 'Warm Neutrals' -%}{%- assign fam_accent = '#CDBA9E' -%}
          {%- when 'Yellows / Sands' -%}{%- assign fam_accent = '#C8A84E' -%}
          {%- when 'Pinks / Coppers' -%}{%- assign fam_accent = '#E0A890' -%}
          {%- when 'Reds / Browns' -%}{%- assign fam_accent = '#B85C42' -%}
        {%- endcase -%}
        <button
          type="button"
          class="vores-farver__filter"
          data-family-filter="{{ fam }}"
          style="--filter-accent: {{ fam_accent }};"
        >
          <span class="vores-farver__filter-dot" style="background-color: {{ fam_accent }};"></span>
          {{ fam_label }}
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%}
      Family arrays come from `{%- include 'paint-colors-data' -%}` at the top of
      this section. Each `*_arr` is a Liquid array of 25 entries encoded as
      `<dlm_id>|<name_da>|<display_hex>`, already in dlm_code order (light → dark).
      Compute max_rows by taking the max of all 8 family sizes.
    {%- endcomment -%}
    {%- assign max_rows = whites_arr.size -%}
    {%- if blues_arr.size   > max_rows -%}{%- assign max_rows = blues_arr.size   -%}{%- endif -%}
    {%- if greys_arr.size   > max_rows -%}{%- assign max_rows = greys_arr.size   -%}{%- endif -%}
    {%- if greens_arr.size  > max_rows -%}{%- assign max_rows = greens_arr.size  -%}{%- endif -%}
    {%- if neutral_arr.size > max_rows -%}{%- assign max_rows = neutral_arr.size -%}{%- endif -%}
    {%- if yellow_arr.size  > max_rows -%}{%- assign max_rows = yellow_arr.size  -%}{%- endif -%}
    {%- if pink_arr.size    > max_rows -%}{%- assign max_rows = pink_arr.size    -%}{%- endif -%}
    {%- if red_arr.size     > max_rows -%}{%- assign max_rows = red_arr.size     -%}{%- endif -%}

    {%- comment -%}
      The grid renders all 200 swatches (25 rows × 8 families) but starts in
      a collapsed state that shows only the first 4 rows = 32 anchor colors.
      The "Vis flere farver" button below toggles the `--collapsed` modifier,
      which hides swatches at position 33+ via CSS. JS handles the label swap.
    {%- endcomment -%}
    <div class="vores-farver__grid vores-farver__grid--collapsed" id="vores-farver-grid">
      {%- for row in (0..max_rows) -%}
        {%- if row >= max_rows -%}{%- break -%}{%- endif -%}
        {%- for fam in families -%}
          {%- assign fam_arr = whites_arr -%}
          {%- case fam -%}
            {%- when 'Whites'          -%}{%- assign fam_arr = whites_arr  -%}
            {%- when 'Blues'           -%}{%- assign fam_arr = blues_arr   -%}
            {%- when 'Greys'           -%}{%- assign fam_arr = greys_arr   -%}
            {%- when 'Greens'          -%}{%- assign fam_arr = greens_arr  -%}
            {%- when 'Warm Neutrals'   -%}{%- assign fam_arr = neutral_arr -%}
            {%- when 'Yellows / Sands' -%}{%- assign fam_arr = yellow_arr  -%}
            {%- when 'Pinks / Coppers' -%}{%- assign fam_arr = pink_arr    -%}
            {%- when 'Reds / Browns'   -%}{%- assign fam_arr = red_arr     -%}
          {%- endcase -%}

          {%- if row < fam_arr.size -%}
            {%- assign entry      = fam_arr[row] -%}
            {%- assign parts      = entry | split: '|' -%}
            {%- assign sw_code    = parts[0] -%}
            {%- assign sw_name    = parts[1] -%}
            {%- assign sw_hex     = parts[2] -%}
            <button
              type="button"
              class="vores-farver__swatch"
              data-color-name="{{ sw_name }}"
              data-color-code="{{ sw_code }}"
              data-color-hex="{{ sw_hex }}"
              data-family="{{ fam }}"
              aria-label="{{ sw_name }} ({{ sw_code }})"
            >
              <span class="vores-farver__swatch-chip" style="background-color: {{ sw_hex }};"></span>
              <span class="vores-farver__swatch-label">
                <span class="vores-farver__swatch-name">{{ sw_name }}</span>
                <span class="vores-farver__swatch-code">{{ sw_code }}</span>
              </span>
            </button>
          {%- else -%}
            <span class="vores-farver__swatch vores-farver__swatch--empty" data-family="{{ fam }}" data-empty="true" aria-hidden="true"></span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <div class="vores-farver__more">
      <button
        type="button"
        class="vores-farver__more-btn"
        id="vores-farver-more-btn"
        aria-expanded="false"
        aria-controls="vores-farver-grid"
      >
        <span class="vores-farver__more-label" data-more-label>Vis flere farver</span>
        <svg
          class="vores-farver__more-icon"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  {%- comment -%}
    Inspiration section — hidden by default, expands when user clicks a swatch.
    Sits OUTSIDE the centered grid so the gallery can stretch to the section width.
  {%- endcomment -%}
  <div class="vores-farver__inspiration" id="vores-farver-inspiration">
    <div class="vores-farver__inspiration-inner">
      <div class="vores-farver__inspiration-header">
        <div class="vores-farver__inspiration-title">
          <span class="vores-farver__eyebrow">INSPIRATION</span>
          <h2 class="vores-farver__inspiration-h">Se <span class="vores-farver__color-emphasis" id="vf-color-name">farven</span> i brug</h2>
          <p>Sådan ser denne farve ud i forskellige rum og på forskellige overflader.</p>
        </div>
        <div class="vores-farver__swatch-card">
          <div class="vores-farver__swatch-card-chip" id="vf-swatch-chip"></div>
          <div class="vores-farver__swatch-card-meta">
            <div class="vores-farver__swatch-card-name" id="vf-swatch-name">—</div>
            <div class="vores-farver__swatch-card-code" id="vf-swatch-code">—</div>
          </div>
        </div>
      </div>

      {%- comment -%}
        Stue photo for the selected color (rendered by JS — uses the
        photo from the vf-color-photos map when present, or falls back
        to the stylised SVG room).
      {%- endcomment -%}
      <div class="vf-photo" id="vf-photo-mount"></div>

      {%- comment -%}
        3-step configurator + decision card. Rendered by the finder JS in
        renderConfigurator(). Replaces the old product cards + sample CTA
        — those visuals are gone but the underlying variant map below
        still drives the cart-add price/variant lookup.
      {%- endcomment -%}
      <div class="vf-cfg" id="vf-cfg-mount"></div>
    </div>
  </div>
</div>

{%- comment -%}
  Variant lookup map — the JS uses it to resolve handle||color||size into a
  variant ID, price, and availability when the user picks (surface, finish,
  size, color) in the configurator.

  Each paint product carries up to 200 colors × 4 sizes = 800 variants.
  Across the five live configurator products that's ~4,000 variants total —
  too large to inline if we also embed image + title per variant. So:

    • `variants` carries only the cart-essential fields per (handle,color,size)
    • `products` is a small (1 entry × 5 handles) map with image + title that
      the JS reads when it needs to render the preview / cart-line. The
      preview falls back to this whenever the variant has no image of its
      own — which is the case for every color past the original 32, since
      the bake-images script only attaches variant images per Størrelse.

  Edit `cfg_handles` when adding/removing finish products from the
  configurator: each handle here must match a real Shopify product with
  Farve + Størrelse options.
{%- endcomment -%}
{%- comment -%}
  Keep this in sync with CFG_SURFACES in assets/kmeconsulting-product-finder.js.
  Only handles for products that exist in Shopify AND carry the full 200-color
  palette belong here — others would silently no-op in the variant map.
  Skipped intentionally:
    loftmaling-glans-2   — product not in catalogue
    trae-metal-glans-30  — product not in catalogue
    trae-metal-glans-10/20/25/60 — exist, but only 32 of 200 colors
    traebeskyttelse-glans-10/40  — exist, but only 32 of 200 colors
{%- endcomment -%}
{%- assign cfg_handles = 'vaegmaling-glans-5,vaegmaling-glans-10,loftmaling-glans-5,trae-metal-glans-40,traebeskyttelse-glans-20' | split: ',' -%}
<script id="product-finder-variant-map" type="application/json">
{
  "products": {
    {%- assign first_p = true -%}
    {%- for handle in cfg_handles -%}
      {%- assign product = all_products[handle] -%}
      {%- if product.id == blank -%}{%- continue -%}{%- endif -%}
      {%- unless first_p -%},{%- endunless -%}
      {%- assign first_p = false -%}
      {{ handle | json }}: {
        "title": {{ product.title | json }},
        "image": {{ product.featured_image | image_url: width: 600 | json }}
      }
    {%- endfor -%}
  },
  "variants": [
    {%- assign first = true -%}
    {%- for handle in cfg_handles -%}
      {%- assign product = all_products[handle] -%}
      {%- if product.id == blank -%}{%- continue -%}{%- endif -%}

      {%- assign farve_position = 0 -%}
      {%- assign size_position = 0 -%}
      {%- for option in product.options_with_values -%}
        {%- if option.name == 'Farve' -%}{%- assign farve_position = forloop.index -%}{%- endif -%}
        {%- if option.name == 'Størrelse' -%}{%- assign size_position = forloop.index -%}{%- endif -%}
      {%- endfor -%}
      {%- if farve_position == 0 or size_position == 0 -%}{%- continue -%}{%- endif -%}

      {%- comment -%}
        Explicit `limit:` keeps Liquid's default for-loop cap (50) from
        truncating large variant arrays. Bumped well past the largest
        product (800 variants today).
      {%- endcomment -%}
      {%- for variant in product.variants limit: 2000 -%}
        {%- assign color_value = '' -%}
        {%- assign size_value = '' -%}
        {%- if farve_position == 1 -%}{%- assign color_value = variant.option1 -%}
        {%- elsif farve_position == 2 -%}{%- assign color_value = variant.option2 -%}
        {%- elsif farve_position == 3 -%}{%- assign color_value = variant.option3 -%}
        {%- endif -%}
        {%- if size_position == 1 -%}{%- assign size_value = variant.option1 -%}
        {%- elsif size_position == 2 -%}{%- assign size_value = variant.option2 -%}
        {%- elsif size_position == 3 -%}{%- assign size_value = variant.option3 -%}
        {%- endif -%}
        {%- if color_value == blank or size_value == blank -%}{%- continue -%}{%- endif -%}

        {%- unless first -%},{%- endunless -%}
        {%- assign first = false -%}
    {
      "handle": {{ handle | json }},
      "color": {{ color_value | json }},
      "size": {{ size_value | json }},
      "variant_id": {{ variant.id | json }},
      "available": {{ variant.available }},
      "price": {{ variant.price | money | json }}
    }
      {%- endfor -%}
    {%- endfor -%}
  ]
}
</script>

{%- comment -%}
