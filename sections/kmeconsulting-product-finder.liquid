{%- comment -%}
  Floating preview — single global element that the cursor positions absolutely.
{%- endcomment -%}
<div class="vores-farver__hover-preview" id="vf-hover-preview" aria-hidden="true">
  <div class="vores-farver__hover-preview-scene" id="vf-hover-preview-scene"></div>
  <div class="vores-farver__hover-preview-meta">
    <div>
      <div class="vores-farver__hover-preview-name" id="vf-hover-name">—</div>
      <div class="vores-farver__hover-preview-code" id="vf-hover-code">—</div>
    </div>
    <div class="vores-farver__hover-preview-click">Klik for mere →</div>
  </div>
</div>

<style>
  /* ── Header ─────────────────────────────────────────────────────── */
  /* Don't use `margin: 0 auto` here — the section's central grid column
     already caps + centers us, and `margin: auto` in a grid item context
     makes the element shrink to its content width (which collapses the
     grid below to its min-content). Just fill the track. */
  .vores-farver {
    width: 100%;
    padding: 0 0 24px;
  }

  .vores-farver__header {
    text-align: center;
    margin-bottom: 36px;
  }

  .vores-farver__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.55);
    margin-bottom: 12px;
  }

  .vores-farver__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 550;
    line-height: 1.1;
    margin: 0 0 12px;
    text-wrap: balance;
  }

  .vores-farver__lead {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.7);
    font-size: 1rem;
    max-width: 540px;
    margin: 0 auto;
  }

  .vores-farver__hint {
    margin-top: 16px;
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.6);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .vores-farver__hint-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-foreground, #1a1612);
    animation: vores-farver-pulse 2s infinite;
  }

  @keyframes vores-farver-pulse {
    0%, 100% { opacity: 0.3; }
    50%      { opacity: 1; }
  }

  /* ── Filter pills (matches Farvekatalog nav) ────────────────────── */
  .vores-farver__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-top: 28px;
  }

  .vores-farver__filter {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 100px;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    color: inherit;
    background: transparent;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.15s ease, background-color 0.2s ease;
  }

  .vores-farver__filter:hover {
    border-color: var(--filter-accent, currentColor);
    transform: translateY(-1px);
  }

  .vores-farver__filter--active {
    border-color: var(--filter-accent, var(--color-foreground));
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.04);
  }

  .vores-farver__filter-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgb(0 0 0 / 0.06);
  }

  /* ── Color grid (mockup 8-col layout) ───────────────────────────── */
  .vores-farver__grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 12px;
    margin-top: 28px;
    width: 100%;
  }

  .vores-farver__swatch--hidden {
    display: none !important;
  }

  /* Collapsed state: show only the first 32 swatches (4 rows × 8 columns).
     The grid puts items in row-major order (row 0 = lightest per family),
     so :nth-child(n+33) is exactly "everything past row 3". When a family
     filter is active, JS hides everything outside that family separately;
     the user can click "Vis flere farver" to expand and see all 25 shades
     of that family. */
  .vores-farver__grid--collapsed > .vores-farver__swatch:nth-child(n+33) {
    display: none;
  }

  /* "Vis flere farver" toggle button — sits under the grid, centered.
     Style matches the filter pills above for visual consistency. */
  .vores-farver__more {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .vores-farver__more-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    color: inherit;
    background: transparent;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.2);
    border-radius: 100px;
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.15s ease;
  }

  .vores-farver__more-btn:hover {
    border-color: var(--color-foreground, currentColor);
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.04);
    transform: translateY(-1px);
  }

  .vores-farver__more-btn:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  .vores-farver__more-icon {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .vores-farver__more-btn[aria-expanded="true"] .vores-farver__more-icon {
    transform: rotate(180deg);
  }

  /* Filter cascade: visible swatches fade in with a small per-item stagger
     applied via inline animation-delay from JS. `both` keeps the swatch at
     opacity 0 during the delay so there's no flash before its turn. */
  @keyframes vores-farver-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .vores-farver__swatch--fade-in {
    animation: vores-farver-fade-in 0.35s ease both;
  }

  @media (prefers-reduced-motion: reduce) {
    .vores-farver__swatch--fade-in { animation: none; }
  }

  @media (max-width: 900px) {
    .vores-farver__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  @media (max-width: 480px) {
    .vores-farver__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .vores-farver__swatch {
    position: relative;
    aspect-ratio: 1 / 1.25;
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
    background: #fff;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    padding: 0;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    color: inherit;
    text-align: center;
  }

  .vores-farver__swatch:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 18px 36px -12px rgba(0, 0, 0, 0.25);
    z-index: 2;
  }

  .vores-farver__swatch:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  .vores-farver__swatch--selected {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  .vores-farver__swatch--empty {
    visibility: hidden;
    pointer-events: none;
  }

  .vores-farver__swatch-chip {
    position: absolute;
    inset: 0 0 34% 0;
    display: block;
    box-shadow: inset 0 0 0 1px rgb(0 0 0 / 0.06), inset 0 -1px 0 0 rgb(0 0 0 / 0.05);
  }

  .vores-farver__swatch-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 8px 6px;
    background: #fff;
    text-align: center;
  }

  .vores-farver__swatch-name {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-foreground, #1a1612);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .vores-farver__swatch-code {
    display: block;
    font-size: 9px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    font-family: 'SF Mono', Menlo, monospace;
    margin-top: 1px;
  }

  /* ── Floating hover preview ─────────────────────────────────────── */
  .vores-farver__hover-preview {
    position: fixed;
    pointer-events: none;
    z-index: 1000;
    width: 260px;
    height: 220px;
    border-radius: 6px;
    box-shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.18s ease, transform 0.18s ease;
    background: #fff;
    border: 1px solid rgba(255, 255, 255, 0.8);
  }

  .vores-farver__hover-preview[data-visible="true"] {
    opacity: 1;
    transform: scale(1);
  }

  .vores-farver__hover-preview-scene {
    height: 170px;
    position: relative;
    overflow: hidden;
  }

  .vores-farver__hover-preview-scene svg,
  .vores-farver__hover-preview-photo {
    width: 100%;
    height: 100%;
    display: block;
  }

  .vores-farver__hover-preview-photo {
    object-fit: cover;
  }

  .vores-farver__hover-preview-meta {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 14px;
    background: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
  }

  .vores-farver__hover-preview-name {
    font-size: 13px;
    font-weight: 600;
  }

  .vores-farver__hover-preview-code {
    font-size: 10px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    font-family: 'SF Mono', monospace;
    margin-top: 1px;
  }

  .vores-farver__hover-preview-click {
    font-size: 10px;
    font-weight: 600;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Respect users who don't want pointer-driven UI */
  @media (hover: none) {
    .vores-farver__hover-preview { display: none !important; }
  }

  /* ── Inspiration section (expand on click) ──────────────────────── */
  /* Inspiration spans the full section width so its tinted background
     extends edge-to-edge, but the content inside is placed in the same
     central column as the rest of the page (so it lines up with the
     header + grid above). */
  .vores-farver__inspiration {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: var(--full-page-grid-with-margins);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.6s ease;
    background: #f2ece1;
    margin-top: 32px;
  }

  .vores-farver__inspiration[data-open="true"] {
    max-height: 3000px;
  }

  .vores-farver__inspiration-inner {
    grid-column: 2;
    padding: 64px 0;
    width: 100%;
    /* Offset for the sticky site header so the inner panel's top doesn't
       slide behind it when scrollIntoView fires after a swatch click. */
    scroll-margin-top: calc(var(--header-group-height, var(--header-height, 60px)) + 16px);
  }

  .vores-farver__inspiration-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .vores-farver__inspiration-h {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    margin: 6px 0 8px;
    line-height: 1.05;
  }

  .vores-farver__color-emphasis {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.55);
    font-style: italic;
  }

  .vores-farver__inspiration-title p {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.65);
    max-width: 480px;
  }

  .vores-farver__swatch-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #fff;
    padding: 14px 18px;
    border-radius: 2px;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    min-width: 240px;
  }

  .vores-farver__swatch-card-chip {
    width: 48px;
    height: 48px;
    border-radius: 2px;
    background: var(--insp-color, #ccc);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .vores-farver__swatch-card-name {
    font-weight: 600;
    font-size: 14px;
  }

  .vores-farver__swatch-card-code {
    font-size: 11px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    font-family: 'SF Mono', monospace;
  }

  /* Gallery — image on the left, surface picker ("Vælg overflade") on
     the right. When more room photos come back, this can become a wider
     grid containing multiple tiles in the left column. */
  .vores-farver__gallery {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 24px;
    min-height: 480px;
    align-items: stretch;
  }

  @media (max-width: 900px) {
    .vores-farver__gallery {
      grid-template-columns: 1fr;
      min-height: 0;
    }
  }

  .vores-farver__tile {
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    background: #fff;
  }

  /* ── Surface picker (Vælg overflade) ────────────────────────────── */
  .vores-farver__surface-picker {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 28px;
    background: #fff;
    border-radius: 4px;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
  }

  .vores-farver__surface-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .vores-farver__surface-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .vores-farver__surface-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 18px;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    color: inherit;
    background: transparent;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.12);
    border-radius: 2px;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.18s ease, background-color 0.18s ease, transform 0.12s ease;
  }

  .vores-farver__surface-option:hover {
    border-color: var(--color-foreground);
    transform: translateY(-1px);
  }

  .vores-farver__surface-option--selected {
    border-color: var(--color-foreground);
    background: var(--color-foreground);
    color: var(--color-background, #fff);
  }

  .vores-farver__tile svg,
  .vores-farver__tile-photo {
    width: 100%;
    height: 100%;
    display: block;
  }

  .vores-farver__tile-photo {
    object-fit: cover;
  }

  .vores-farver__tile-label {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255, 255, 255, 0.9);
    padding: 5px 10px;
    font-size: 11px;
    font-weight: 500;
    border-radius: 2px;
    color: var(--color-foreground, #1a1612);
    letter-spacing: 0.04em;
  }

  /* Product cards (one per paint-type, color pre-selected) */
  .vores-farver__products {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .vores-farver__products { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .vores-farver__products { grid-template-columns: 1fr; }
  }

  .vores-farver__product {
    background: #fff;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
    border-radius: 4px;
    padding: 18px;
    display: flex;
    gap: 14px;
    align-items: center;
    color: inherit;
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .vores-farver__product:hover {
    box-shadow: 0 4px 16px -4px rgba(0, 0, 0, 0.12);
    transform: translateY(-1px);
  }

  .vores-farver__product-thumb {
    width: 56px;
    height: 68px;
    border-radius: 2px;
    background: linear-gradient(180deg, var(--insp-color, #ccc) 0%, var(--insp-color, #ccc) 70%, #1a1612 70%, #1a1612 100%);
    flex-shrink: 0;
    position: relative;
  }

  .vores-farver__product-thumb::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 48%;
    width: 70%;
    height: 3px;
    background: #fff;
    opacity: 0.5;
  }

  .vores-farver__product-meta {
    min-width: 0;
  }

  .vores-farver__product-name {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 2px;
  }

  .vores-farver__product-desc {
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.55);
    margin: 0;
  }

  .vores-farver__product-price {
    font-size: 13px;
    font-weight: 600;
    margin-top: 6px;
  }

  /* CTA box */
  .vores-farver__cta {
    margin-top: 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: #fff;
    padding: 24px 32px;
    border-radius: 4px;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    flex-wrap: wrap;
  }

  .vores-farver__cta-text h3 {
    font-size: 22px;
    margin: 0 0 4px;
  }

  .vores-farver__cta-text p {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.6);
    font-size: 14px;
    margin: 0;
  }

  .vores-farver__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 2px;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background-color 0.2s ease, transform 0.2s ease;
    border: 1px solid var(--color-foreground, #1a1612);
  }

  .vores-farver__btn--primary {
    background: var(--color-foreground, #1a1612);
    color: var(--color-background, #fff);
  }

  .vores-farver__btn--primary:hover { transform: translateY(-1px); }

  .vores-farver__btn svg {
    width: 14px;
    height: 14px;
  }

  /* ──────────────────────────────────────────────────────────────────
     Stue photo above the configurator
     ────────────────────────────────────────────────────────────────── */
  .vf-photo {
    width: 100%;
    margin-bottom: 24px;
  }

  .vf-photo__tile {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
  }

  @media (max-width: 700px) {
    .vf-photo__tile { aspect-ratio: 4 / 3; }
  }

  .vf-photo__tile img,
  .vf-photo__tile svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .vf-photo__label {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255, 255, 255, 0.9);
    padding: 5px 10px;
    font-size: 11px;
    font-weight: 500;
    border-radius: 2px;
    color: #1a1612;
    letter-spacing: 0.04em;
  }

  /* ──────────────────────────────────────────────────────────────────
     Inspiration configurator — 3-step picker + decision card
     ────────────────────────────────────────────────────────────────── */
  .vf-cfg {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(320px, 1fr);
    gap: 24px;
    align-items: start;
    color: #1a1612;
  }

  @media (max-width: 900px) {
    .vf-cfg { grid-template-columns: 1fr; }
  }

  /* ── Step columns ───────────────────────────────────────────────── */
  .vf-cfg__steps {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .vf-cfg__step {
    background: #fff;
    border: 1px solid rgb(26 22 18 / 0.1);
    border-radius: 4px;
    padding: 28px 28px 26px;
  }

  .vf-cfg__legend {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 20px;
    padding: 0;
    width: 100%;
  }

  .vf-cfg__step-num {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: rgb(26 22 18 / 0.45);
    flex-shrink: 0;
  }

  .vf-cfg__step-title {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: clamp(1.4rem, 2vw, 1.65rem);
    font-weight: 500;
    line-height: 1.15;
  }

  /* ── Step 1 — surface cards (large, with subtitle + tag) ────────── */
  .vf-cfg__surface-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  @media (max-width: 700px) {
    .vf-cfg__surface-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .vf-cfg__surface {
    font: inherit;
    text-align: left;
    padding: 18px 16px;
    background: #f2ece1;
    color: #1a1612;
    border: 1px solid transparent;
    border-radius: 3px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 150px;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .vf-cfg__surface:hover {
    border-color: rgb(26 22 18 / 0.25);
  }

  .vf-cfg__surface[aria-checked="true"] {
    background: #1a1612;
    color: #faf6ed;
    border-color: #1a1612;
  }

  .vf-cfg__surface-title {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.05;
  }

  .vf-cfg__surface-sub {
    font-size: 0.85rem;
    color: rgb(26 22 18 / 0.65);
  }

  .vf-cfg__surface[aria-checked="true"] .vf-cfg__surface-sub {
    color: rgb(250 246 237 / 0.7);
  }

  .vf-cfg__surface-tag {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(26 22 18 / 0.5);
    margin-top: auto;
  }

  .vf-cfg__surface[aria-checked="true"] .vf-cfg__surface-tag {
    color: rgb(250 246 237 / 0.6);
  }

  /* ── Step 2 — finish cards ──────────────────────────────────────── */
  .vf-cfg__finish-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }

  .vf-cfg__finish {
    font: inherit;
    text-align: left;
    padding: 22px 22px 20px;
    background: #f2ece1;
    color: #1a1612;
    border: 1px solid transparent;
    border-radius: 3px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    position: relative;
  }

  .vf-cfg__finish:hover {
    border-color: rgb(26 22 18 / 0.25);
  }

  .vf-cfg__finish[aria-checked="true"] {
    background: #fff;
    border-color: #1a1612;
    border-width: 1.5px;
    padding: 21.5px 21.5px 19.5px;
  }

  .vf-cfg__finish-glans {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(26 22 18 / 0.55);
  }

  .vf-cfg__finish-name {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1;
  }

  .vf-cfg__finish-desc {
    font-size: 0.9rem;
    color: rgb(26 22 18 / 0.7);
    line-height: 1.4;
  }

  .vf-cfg__badge {
    position: absolute;
    top: 16px;
    right: 16px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 8px;
    background: #c5d2b6;
    color: #1a1612;
    border-radius: 2px;
  }

  /* ── Step 3 — size chips ────────────────────────────────────────── */
  .vf-cfg__size-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  @media (max-width: 600px) {
    .vf-cfg__size-grid { grid-template-columns: 1fr; }
  }

  .vf-cfg__size {
    font: inherit;
    text-align: left;
    padding: 22px 22px 18px;
    background: #f2ece1;
    color: #1a1612;
    border: 1px solid transparent;
    border-radius: 3px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .vf-cfg__size:hover {
    border-color: rgb(26 22 18 / 0.25);
  }

  .vf-cfg__size[aria-checked="true"] {
    background: #1a1612;
    color: #faf6ed;
    border-color: #1a1612;
  }

  .vf-cfg__size-label {
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: 1.55rem;
    font-weight: 500;
    line-height: 1;
  }

  .vf-cfg__size-coverage {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(26 22 18 / 0.55);
  }

  .vf-cfg__size[aria-checked="true"] .vf-cfg__size-coverage {
    color: rgb(250 246 237 / 0.7);
  }

  /* ── Decision card (right rail) ─────────────────────────────────── */
  .vf-cfg__decision {
    background: #fff;
    border: 1px solid rgb(26 22 18 / 0.1);
    border-radius: 4px;
    padding: 24px 24px 22px;
    position: sticky;
    top: calc(var(--header-group-height, var(--header-height, 60px)) + 16px);
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  @media (max-width: 900px) {
    .vf-cfg__decision { position: static; }
  }

  /* Real Shopify product image at the top of the decision card.
     Image is absolutely positioned with inset padding so it always
     fits inside the box regardless of the source image's aspect ratio
     — `object-fit: contain` then centers + scales it down. */
  .vf-cfg__product-preview {
    aspect-ratio: 5 / 3;
    background: #f2ece1;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }

  .vf-cfg__product-preview img {
    position: absolute;
    inset: 14px;
    width: calc(100% - 28px);
    height: calc(100% - 28px);
    object-fit: contain;
    display: block;
  }

  /* Summary list */
  .vf-cfg__summary {
    margin: 0;
    padding: 16px 0;
    border-top: 1px solid rgb(26 22 18 / 0.08);
    border-bottom: 1px solid rgb(26 22 18 / 0.08);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .vf-cfg__summary > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  .vf-cfg__summary dt {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(26 22 18 / 0.5);
    flex-shrink: 0;
  }

  .vf-cfg__summary dd {
    margin: 0;
    font-size: 0.95rem;
    text-align: right;
    font-weight: 500;
  }

  /* CTA section */
  .vf-cfg__cta-eyebrow {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(26 22 18 / 0.5);
    margin: 0;
  }

  .vf-cfg__cta {
    font: inherit;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 14px;
    row-gap: 2px;
    padding: 14px 18px;
    border-radius: 3px;
    cursor: pointer;
    text-align: left;
    width: 100%;
    transition: transform 0.12s ease, opacity 0.15s ease;
  }

  .vf-cfg__cta:hover { transform: translateY(-1px); }
  .vf-cfg__cta:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .vf-cfg__cta-icon {
    grid-row: 1 / 3;
    align-self: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .vf-cfg__cta-icon svg {
    width: 18px;
    height: 18px;
  }

  .vf-cfg__cta-label {
    font-size: 1rem;
    font-weight: 600;
    grid-column: 2;
    align-self: end;
  }

  .vf-cfg__cta-price {
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 1rem;
    font-weight: 600;
    grid-column: 3;
    align-self: end;
  }

  .vf-cfg__cta-sub {
    grid-column: 2 / 4;
    font-size: 0.78rem;
    color: rgb(26 22 18 / 0.6);
  }

  .vf-cfg__cta--sample {
    background: #fff;
    color: #1a1612;
    border: 1.5px solid #1a1612;
  }

  .vf-cfg__cta--sample .vf-cfg__cta-icon {
    background: #f2ece1;
    color: #1a1612;
  }

  .vf-cfg__cta--primary {
    background: #1a1612;
    color: #faf6ed;
    border: 1.5px solid #1a1612;
  }

  .vf-cfg__cta--primary .vf-cfg__cta-icon {
    background: rgb(255 255 255 / 0.12);
    color: #faf6ed;
  }

  .vf-cfg__cta--primary .vf-cfg__cta-sub {
    color: rgb(250 246 237 / 0.7);
  }

  /* "ELLER" divider between the two CTAs */
  .vf-cfg__or {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(26 22 18 / 0.4);
    text-align: center;
    margin: 4px 0;
  }

  .vf-cfg__or::before,
  .vf-cfg__or::after {
    content: '';
    flex: 1;
    border-top: 1px dashed rgb(26 22 18 / 0.2);
  }

  /* Soft hint with checkmark */
  .vf-cfg__hint {
    margin: 6px 0 0;
    padding: 12px 14px;
    background: #f2ece1;
    border-radius: 3px;
    font-size: 0.82rem;
    color: rgb(26 22 18 / 0.7);
    line-height: 1.45;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .vf-cfg__hint svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 2px;
    color: #1a1612;
  }

  .vf-cfg__error {
    margin: 4px 0 0;
    padding: 10px 12px;
    background: #fce7e1;
    color: #b85c42;
    border-radius: 3px;
    font-size: 0.85rem;
  }
</style>

{{ 'kmeconsulting-product-finder.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Produktfinder",
  "class": "kmeconsulting-product-finder",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Vores farver"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Hver farve er udviklet i Danmark. Hold musen over en farve for at se den i et rum — klik for at se den i flere."
    },
    {
      "type": "collection",
