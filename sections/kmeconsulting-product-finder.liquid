{%- liquid
  assign colors = shop.metaobjects['paint_color'].values
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  id="product-finder"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="vores-farver">
    <div class="vores-farver__header">
      <span class="vores-farver__eyebrow">VORES FARVER · 32 NUANCER</span>
      {%- if section.settings.heading != blank -%}
        <h2 class="vores-farver__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="vores-farver__lead">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="vores-farver__hint">
        <span class="vores-farver__hint-dot" aria-hidden="true"></span>
        <span>Prøv det: hold musen hen over en farve</span>
      </div>
    </div>

    {%- comment -%}
      Render the 32 colors as an 8-column grid grouped by family.
      Each column = a color family (Whites, Blues, Greys, Greens, …),
      sorted top → bottom from lightest to darkest by DLM code.
    {%- endcomment -%}

    {%- assign family_list = '' -%}
    {%- for color in colors -%}
      {%- assign fam = color.color_family.value | default: color.color_family -%}
      {%- unless family_list contains fam -%}
        {%- unless family_list == '' -%}{%- assign family_list = family_list | append: '|||' -%}{%- endunless -%}
        {%- assign family_list = family_list | append: fam -%}
      {%- endunless -%}
    {%- endfor -%}
    {%- assign families = family_list | split: '|||' | sort -%}

    {%- assign max_rows = 0 -%}
    {%- for fam in families -%}
      {%- assign fam_count = 0 -%}
      {%- for color in colors -%}
        {%- assign c_fam = color.color_family.value | default: color.color_family -%}
        {%- if c_fam == fam -%}
          {%- assign fam_count = fam_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if fam_count > max_rows -%}
        {%- assign max_rows = fam_count -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="vores-farver__grid" id="vores-farver-grid">
      {%- for row in (0..max_rows) -%}
        {%- if row >= max_rows -%}{%- break -%}{%- endif -%}
        {%- for fam in families -%}
          {%- assign fam_codes = '' -%}
          {%- for color in colors -%}
            {%- assign c_fam = color.color_family.value | default: color.color_family -%}
            {%- if c_fam == fam -%}
              {%- assign c_code = color.dlm_code.value | default: color.dlm_code -%}
              {%- unless fam_codes == '' -%}{%- assign fam_codes = fam_codes | append: ',' -%}{%- endunless -%}
              {%- assign fam_codes = fam_codes | append: c_code -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign sorted_codes = fam_codes | split: ',' | sort -%}

          {%- if row < sorted_codes.size -%}
            {%- assign target_code = sorted_codes[row] -%}
            {%- for color in colors -%}
              {%- assign c_code = color.dlm_code.value | default: color.dlm_code -%}
              {%- if c_code == target_code -%}
                <button
                  type="button"
                  class="vores-farver__swatch"
                  data-color-name="{{ color.name.value }}"
                  data-color-code="{{ color.dlm_code.value }}"
                  data-color-hex="{{ color.hex_color.value }}"
                  aria-label="{{ color.name.value }} ({{ color.dlm_code.value }})"
                >
                  <span class="vores-farver__swatch-chip" style="background-color: {{ color.hex_color.value }};"></span>
                  <span class="vores-farver__swatch-label">
                    <span class="vores-farver__swatch-name">{{ color.name.value }}</span>
                    <span class="vores-farver__swatch-code">{{ color.dlm_code.value }}</span>
                  </span>
                </button>
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <span class="vores-farver__swatch vores-farver__swatch--empty" aria-hidden="true"></span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%}
    Inspiration section — hidden by default, expands when user clicks a swatch.
    Sits OUTSIDE the centered grid so the gallery can stretch to the section width.
  {%- endcomment -%}
  <div class="vores-farver__inspiration" id="vores-farver-inspiration">
    <div class="vores-farver__inspiration-inner">
      <div class="vores-farver__inspiration-header">
        <div class="vores-farver__inspiration-title">
          <span class="vores-farver__eyebrow">INSPIRATION</span>
          <h2 class="vores-farver__inspiration-h">Se <span class="vores-farver__color-emphasis" id="vf-color-name">farven</span> i brug</h2>
          <p>Sådan ser denne farve ud i forskellige rum og på forskellige overflader.</p>
        </div>
        <div class="vores-farver__swatch-card">
          <div class="vores-farver__swatch-card-chip" id="vf-swatch-chip"></div>
          <div class="vores-farver__swatch-card-meta">
            <div class="vores-farver__swatch-card-name" id="vf-swatch-name">—</div>
            <div class="vores-farver__swatch-card-code" id="vf-swatch-code">—</div>
          </div>
        </div>
      </div>

      <div class="vores-farver__gallery" id="vf-gallery"></div>

      <div class="vores-farver__products" id="vf-products"></div>

      <div class="vores-farver__cta">
        <div class="vores-farver__cta-text">
          <h3>Kan du lide farven? Få en gratis prøve.</h3>
          <p>Vi sender op til 5 farveprøver til din dør — så du kan se dem i dit eget lys, før du bestiller.</p>
        </div>
        <div class="vores-farver__cta-actions">
          <a class="vores-farver__btn vores-farver__btn--primary" href="/pages/contact">
            Bestil gratis prøve
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%}
  Variant lookup map — same structure used by the previous wizard. The JS uses
  it to link product suggestion cards to the right PDP variant.
{%- endcomment -%}
<script id="product-finder-variant-map" type="application/json">
{
  "variants": [
    {%- assign finder_pairs = 'vaegmaling-glans-10|Vægmaling,loftmaling-glans-5|Loftmaling,trae-metal-glans-30|Træ & Metal,strukturmaling-glans-5|Strukturmaling,traebeskyttelse-glans-20|Træbeskyttelse,gulvmaling-glans-40|Gulvmaling' | split: ',' -%}
    {%- assign first = true -%}
    {%- for pair in finder_pairs -%}
      {%- assign parts = pair | split: '|' -%}
      {%- assign handle = parts[0] -%}
      {%- assign paint_type_name = parts[1] -%}
      {%- assign product = all_products[handle] -%}
      {%- if product.id == blank -%}{%- continue -%}{%- endif -%}

      {%- assign farve_position = 0 -%}
      {%- for option in product.options_with_values -%}
        {%- if option.name == 'Farve' -%}
          {%- assign farve_position = forloop.index -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if farve_position == 0 -%}{%- continue -%}{%- endif -%}

      {%- assign seen_colors = '' -%}
      {%- for variant in product.variants -%}
        {%- assign color_value = '' -%}
        {%- if farve_position == 1 -%}{%- assign color_value = variant.option1 -%}
        {%- elsif farve_position == 2 -%}{%- assign color_value = variant.option2 -%}
        {%- elsif farve_position == 3 -%}{%- assign color_value = variant.option3 -%}
        {%- endif -%}
        {%- if color_value == blank -%}{%- continue -%}{%- endif -%}
        {%- capture seen_key -%}|{{ color_value }}|{%- endcapture -%}
        {%- unless seen_colors contains seen_key -%}
          {%- unless first -%},{%- endunless -%}
          {%- assign first = false -%}
          {%- assign variant_image = variant.featured_image | default: product.featured_image -%}
    {
      "paint_type": {{ paint_type_name | json }},
      "color": {{ color_value | json }},
      "handle": {{ product.handle | json }},
      "variant_id": {{ variant.id | json }},
      "product_title": {{ product.title | json }},
      "image": {{ variant_image | image_url: width: 200 | json }},
      "price": {{ product.price | money | json }}
    }
          {%- assign seen_colors = seen_colors | append: seen_key -%}
        {%- endunless -%}
      {%- endfor -%}
    {%- endfor -%}
  ]
}
</script>

{%- comment -%}
  Floating preview — single global element that the cursor positions absolutely.
{%- endcomment -%}
<div class="vores-farver__hover-preview" id="vf-hover-preview" aria-hidden="true">
  <div class="vores-farver__hover-preview-scene" id="vf-hover-preview-scene"></div>
  <div class="vores-farver__hover-preview-meta">
    <div>
      <div class="vores-farver__hover-preview-name" id="vf-hover-name">—</div>
      <div class="vores-farver__hover-preview-code" id="vf-hover-code">—</div>
    </div>
    <div class="vores-farver__hover-preview-click">Klik for mere →</div>
  </div>
</div>

<style>
  /* ── Header ─────────────────────────────────────────────────────── */
  /* Don't use `margin: 0 auto` here — the section's central grid column
     already caps + centers us, and `margin: auto` in a grid item context
     makes the element shrink to its content width (which collapses the
     grid below to its min-content). Just fill the track. */
  .vores-farver {
    width: 100%;
    padding: 0 0 24px;
  }

  .vores-farver__header {
    text-align: center;
    margin-bottom: 36px;
  }

  .vores-farver__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.55);
    margin-bottom: 12px;
  }

  .vores-farver__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    margin: 0 0 12px;
    text-wrap: balance;
  }

  .vores-farver__lead {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.7);
    font-size: 1rem;
    max-width: 540px;
    margin: 0 auto;
  }

  .vores-farver__hint {
    margin-top: 16px;
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.6);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .vores-farver__hint-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-foreground, #1a1612);
    animation: vores-farver-pulse 2s infinite;
  }

  @keyframes vores-farver-pulse {
    0%, 100% { opacity: 0.3; }
    50%      { opacity: 1; }
  }

  /* ── Color grid (mockup 8-col layout) ───────────────────────────── */
  .vores-farver__grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 12px;
    margin-top: 28px;
    width: 100%;
  }

  @media (max-width: 900px) {
    .vores-farver__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  @media (max-width: 480px) {
    .vores-farver__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .vores-farver__swatch {
    position: relative;
    aspect-ratio: 1 / 1.25;
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
    background: #fff;
    border: none;
    padding: 0;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    color: inherit;
    text-align: center;
  }

  .vores-farver__swatch:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 18px 36px -12px rgba(0, 0, 0, 0.25);
    z-index: 2;
  }

  .vores-farver__swatch:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  .vores-farver__swatch--selected {
    outline: 2px solid var(--color-foreground);
    outline-offset: 3px;
  }

  .vores-farver__swatch--empty {
    visibility: hidden;
    pointer-events: none;
  }

  .vores-farver__swatch-chip {
    position: absolute;
    inset: 0 0 34% 0;
    display: block;
  }

  .vores-farver__swatch-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 8px 6px;
    background: #fff;
    text-align: center;
  }

  .vores-farver__swatch-name {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-foreground, #1a1612);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .vores-farver__swatch-code {
    display: block;
    font-size: 9px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    font-family: 'SF Mono', Menlo, monospace;
    margin-top: 1px;
  }

  /* ── Floating hover preview ─────────────────────────────────────── */
  .vores-farver__hover-preview {
    position: fixed;
    pointer-events: none;
    z-index: 1000;
    width: 260px;
    height: 220px;
    border-radius: 6px;
    box-shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.18s ease, transform 0.18s ease;
    background: #fff;
    border: 1px solid rgba(255, 255, 255, 0.8);
  }

  .vores-farver__hover-preview[data-visible="true"] {
    opacity: 1;
    transform: scale(1);
  }

  .vores-farver__hover-preview-scene {
    height: 170px;
    position: relative;
    overflow: hidden;
  }

  .vores-farver__hover-preview-scene svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .vores-farver__hover-preview-meta {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 14px;
    background: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
  }

  .vores-farver__hover-preview-name {
    font-size: 13px;
    font-weight: 600;
  }

  .vores-farver__hover-preview-code {
    font-size: 10px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    font-family: 'SF Mono', monospace;
    margin-top: 1px;
  }

  .vores-farver__hover-preview-click {
    font-size: 10px;
    font-weight: 600;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Respect users who don't want pointer-driven UI */
  @media (hover: none) {
    .vores-farver__hover-preview { display: none !important; }
  }

  /* ── Inspiration section (expand on click) ──────────────────────── */
  /* Inspiration spans the full section width so its tinted background
     extends edge-to-edge, but the content inside is placed in the same
     central column as the rest of the page (so it lines up with the
     header + grid above). */
  .vores-farver__inspiration {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: var(--full-page-grid-with-margins);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.6s ease;
    background: rgb(var(--color-foreground-rgb, 0 0 0) / 0.04);
    margin-top: 32px;
  }

  .vores-farver__inspiration[data-open="true"] {
    max-height: 3000px;
  }

  .vores-farver__inspiration-inner {
    grid-column: 2;
    padding: 64px 0;
    width: 100%;
  }

  .vores-farver__inspiration-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .vores-farver__inspiration-h {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    margin: 6px 0 8px;
    line-height: 1.05;
  }

  .vores-farver__color-emphasis {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.55);
    font-style: italic;
  }

  .vores-farver__inspiration-title p {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.65);
    max-width: 480px;
  }

  .vores-farver__swatch-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #fff;
    padding: 14px 18px;
    border-radius: 2px;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    min-width: 240px;
  }

  .vores-farver__swatch-card-chip {
    width: 48px;
    height: 48px;
    border-radius: 2px;
    background: var(--insp-color, #ccc);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .vores-farver__swatch-card-name {
    font-weight: 600;
    font-size: 14px;
  }

  .vores-farver__swatch-card-code {
    font-size: 11px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.4);
    font-family: 'SF Mono', monospace;
  }

  /* Gallery — large primary tile + 5 smaller */
  .vores-farver__gallery {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 12px;
    min-height: 480px;
  }

  @media (max-width: 900px) {
    .vores-farver__gallery {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      min-height: 0;
    }
  }

  .vores-farver__tile {
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    background: #fff;
  }

  .vores-farver__tile:nth-child(1) { grid-row: 1 / 3; }

  @media (max-width: 900px) {
    .vores-farver__tile:nth-child(1) { grid-row: auto; grid-column: 1 / 3; }
  }

  .vores-farver__tile svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .vores-farver__tile-label {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255, 255, 255, 0.9);
    padding: 5px 10px;
    font-size: 11px;
    font-weight: 500;
    border-radius: 2px;
    color: var(--color-foreground, #1a1612);
    letter-spacing: 0.04em;
  }

  /* Product cards (one per paint-type, color pre-selected) */
  .vores-farver__products {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) {
    .vores-farver__products { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .vores-farver__products { grid-template-columns: 1fr; }
  }

  .vores-farver__product {
    background: #fff;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
    border-radius: 4px;
    padding: 18px;
    display: flex;
    gap: 14px;
    align-items: center;
    color: inherit;
    text-decoration: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .vores-farver__product:hover {
    box-shadow: 0 4px 16px -4px rgba(0, 0, 0, 0.12);
    transform: translateY(-1px);
  }

  .vores-farver__product-thumb {
    width: 56px;
    height: 68px;
    border-radius: 2px;
    background: linear-gradient(180deg, var(--insp-color, #ccc) 0%, var(--insp-color, #ccc) 70%, #1a1612 70%, #1a1612 100%);
    flex-shrink: 0;
    position: relative;
  }

  .vores-farver__product-thumb::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 48%;
    width: 70%;
    height: 3px;
    background: #fff;
    opacity: 0.5;
  }

  .vores-farver__product-meta {
    min-width: 0;
  }

  .vores-farver__product-name {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 2px;
  }

  .vores-farver__product-desc {
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.55);
    margin: 0;
  }

  .vores-farver__product-price {
    font-size: 13px;
    font-weight: 600;
    margin-top: 6px;
  }

  /* CTA box */
  .vores-farver__cta {
    margin-top: 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: #fff;
    padding: 24px 32px;
    border-radius: 4px;
    border: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    flex-wrap: wrap;
  }

  .vores-farver__cta-text h3 {
    font-size: 22px;
    margin: 0 0 4px;
  }

  .vores-farver__cta-text p {
    color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.6);
    font-size: 14px;
    margin: 0;
  }

  .vores-farver__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 2px;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background-color 0.2s ease, transform 0.2s ease;
    border: 1px solid var(--color-foreground, #1a1612);
  }

  .vores-farver__btn--primary {
    background: var(--color-foreground, #1a1612);
    color: var(--color-background, #fff);
  }

  .vores-farver__btn--primary:hover { transform: translateY(-1px); }

  .vores-farver__btn svg {
    width: 14px;
    height: 14px;
  }
</style>

{{ 'kmeconsulting-product-finder.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Produktfinder",
  "class": "kmeconsulting-product-finder",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Vores farver"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underoverskrift",
