{%- liquid
  assign combo = resource
  if combo == blank
    assign path_parts = request.path | split: '/'
    assign handle = path_parts | last
    assign all_combos = shop.metaobjects['color_combination'].values
    for c in all_combos
      if c.system.handle == handle
        assign combo = c
        break
      endif
    endfor
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  {%- if combo != blank -%}
    <!-- Hero: name + description + color palette -->
    <div class="color-lab-page__hero">
      <h1 class="color-lab-page__title">{{ combo.name }}</h1>

      {%- if combo.description != blank -%}
        <p class="color-lab-page__description">{{ combo.description }}</p>
      {%- endif -%}

      <div class="color-lab-page__palette">
        {%- for i in (1..5) -%}
          {%- case i -%}
            {%- when 1 -%}{%- assign pc = combo.paint_color_1.value -%}{%- assign fallback_hex = combo.color_1 -%}
            {%- when 2 -%}{%- assign pc = combo.paint_color_2.value -%}{%- assign fallback_hex = combo.color_2 -%}
            {%- when 3 -%}{%- assign pc = combo.paint_color_3.value -%}{%- assign fallback_hex = combo.color_3 -%}
            {%- when 4 -%}{%- assign pc = combo.paint_color_4.value -%}{%- assign fallback_hex = combo.color_4 -%}
            {%- when 5 -%}{%- assign pc = combo.paint_color_5.value -%}{%- assign fallback_hex = combo.color_5 -%}
          {%- endcase -%}

          {%- if pc != blank -%}
            <div class="color-lab-page__color">
              <span class="color-lab-page__swatch" style="background-color: {{ pc.hex_color.value }};"></span>
              <span class="color-lab-page__color-name">{{ pc.name.value }}</span>
              <span class="color-lab-page__color-code">{{ pc.dlm_code.value }}</span>
            </div>
          {%- elsif fallback_hex != blank -%}
            <div class="color-lab-page__color">
              <span class="color-lab-page__swatch" style="background-color: {{ fallback_hex }};"></span>
              <span class="color-lab-page__hex">{{ fallback_hex }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Image gallery -->
    {%- if combo.images.value != blank and combo.images.value.size > 0 -%}
      <div class="color-lab-page__gallery">
        <h2 class="color-lab-page__gallery-heading">Inspiration</h2>
        <div class="color-lab-page__grid">
          {%- for image in combo.images.value -%}
            <div class="color-lab-page__image-wrapper color-lab-page__image-wrapper--{{ forloop.index }}">
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ combo.name }} inspiration {{ forloop.index }}"
                loading="lazy"
                width="800"
                height="{{ 800 | divided_by: image.aspect_ratio | round }}"
                class="color-lab-page__image"
              >
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="color-lab-page__no-images">
        <p>Billeder kommer snart.</p>
      </div>
    {%- endif -%}

    <!-- Paint buckets for each color in the combo -->
    {%- liquid
      assign handle_stem = section.settings.paint_handle_stem | default: 'vaegmaling'
      assign glans_levels_str = section.settings.glans_levels | default: '5,7,10,20'
      assign glans_levels = glans_levels_str | split: ','
      assign default_glans = section.settings.default_glans | default: '5'
      assign size_levels_str = section.settings.size_levels | default: '5L,10L,20L'
      assign size_levels = size_levels_str | split: ','
      assign default_size = section.settings.default_size | default: '5L'

      assign has_any_paint_color = false
      for i in (1..5)
        case i
          when 1
            assign pc_check = combo.paint_color_1.value
          when 2
            assign pc_check = combo.paint_color_2.value
          when 3
            assign pc_check = combo.paint_color_3.value
          when 4
            assign pc_check = combo.paint_color_4.value
          when 5
            assign pc_check = combo.paint_color_5.value
        endcase
        if pc_check != blank
          assign has_any_paint_color = true
        endif
      endfor
    -%}

    {%- if has_any_paint_color -%}
      <div class="color-lab-page__products">
        <h2 class="color-lab-page__products-heading">Maling til denne kombination</h2>
        <div class="color-lab-page__buckets-grid">
          {%- for i in (1..5) -%}
            {%- case i -%}
              {%- when 1 -%}{%- assign pc = combo.paint_color_1.value -%}
              {%- when 2 -%}{%- assign pc = combo.paint_color_2.value -%}
              {%- when 3 -%}{%- assign pc = combo.paint_color_3.value -%}
              {%- when 4 -%}{%- assign pc = combo.paint_color_4.value -%}
              {%- when 5 -%}{%- assign pc = combo.paint_color_5.value -%}
            {%- endcase -%}

            {%- if pc == blank -%}{%- continue -%}{%- endif -%}

            {%- assign default_handle = handle_stem | append: '-glans-' | append: default_glans -%}
            {%- assign default_product = all_products[default_handle] -%}
            {%- if default_product.id == blank -%}{%- continue -%}{%- endif -%}

            {%- assign matching = default_product.variants | where: 'option1', pc.name.value -%}
            {%- assign default_variant = matching | where: 'option2', default_size | first -%}
            {%- if default_variant == blank -%}
              {%- assign default_variant = matching | first -%}
            {%- endif -%}
            {%- if default_variant == blank -%}{%- continue -%}{%- endif -%}

            <div class="color-lab-page__bucket" data-bucket data-variant-id="{{ default_variant.id }}">
              <script type="application/json" data-bucket-data>
                {
                  {%- assign first_g = true -%}
                  {%- for glans in glans_levels -%}
                    {%- assign g_handle = handle_stem | append: '-glans-' | append: glans -%}
                    {%- assign g_product = all_products[g_handle] -%}
                    {%- if g_product.id == blank -%}{%- continue -%}{%- endif -%}
                    {%- assign g_variants = g_product.variants | where: 'option1', pc.name.value -%}
                    {%- if g_variants.size == 0 -%}{%- continue -%}{%- endif -%}
                    {%- unless first_g -%},{%- endunless -%}
                    {%- assign first_g = false -%}
                    {{ glans | json }}: {
                      {%- assign first_s = true -%}
                      {%- for v in g_variants -%}
                        {%- unless first_s -%},{%- endunless -%}
                        {%- assign first_s = false -%}
                        {%- assign v_image = v.featured_image | default: g_product.featured_image -%}
                        {{ v.option2 | json }}: {
                          "id": {{ v.id }},
                          "price": {{ v.price | money | json }},
                          "title": {{ g_product.title | json }},
                          "url": {{ v.url | json }},
                          "image": {{ v_image | image_url: width: 600 | json }},
                          "available": {{ v.available }}
                        }
                      {%- endfor -%}
                    }
                  {%- endfor -%}
                }
              </script>

              <a href="{{ default_variant.url }}" class="color-lab-page__bucket-link" data-bucket-link>
                <div class="color-lab-page__bucket-image-wrapper">
                  {%- assign init_image = default_variant.featured_image | default: default_product.featured_image -%}
                  <img
                    src="{{ init_image | image_url: width: 600 }}"
                    alt="{{ default_product.title }} – {{ pc.name.value }}"
                    loading="lazy"
                    class="color-lab-page__bucket-image"
                    data-bucket-image
                  >
                </div>
              </a>

              <div class="color-lab-page__bucket-info">
                <div class="color-lab-page__bucket-color">
                  <span class="color-lab-page__bucket-swatch" style="background-color: {{ pc.hex_color.value }};"></span>
                  <div class="color-lab-page__bucket-color-text">
                    <span class="color-lab-page__bucket-color-name">{{ pc.name.value }}</span>
                    <span class="color-lab-page__bucket-color-code">{{ pc.dlm_code.value }}</span>
                  </div>
                </div>

                <p class="color-lab-page__bucket-product-title" data-bucket-title>{{ default_product.title }}</p>

                <div class="color-lab-page__bucket-options">
                  <label class="color-lab-page__bucket-option">
                    <span class="color-lab-page__bucket-option-label">Glans</span>
                    <select data-bucket-glans>
                      {%- for glans in glans_levels -%}
                        <option value="{{ glans }}"{% if glans == default_glans %} selected{% endif %}>{{ glans }}</option>
                      {%- endfor -%}
                    </select>
                  </label>

                  <label class="color-lab-page__bucket-option">
                    <span class="color-lab-page__bucket-option-label">Størrelse</span>
                    <select data-bucket-size>
                      {%- for size in size_levels -%}
                        <option value="{{ size }}"{% if size == default_size %} selected{% endif %}>{{ size }}</option>
                      {%- endfor -%}
                    </select>
                  </label>
                </div>

                <p class="color-lab-page__bucket-price" data-bucket-price>{{ default_variant.price | money }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="color-lab-page__add-combo">
          <button type="button" class="color-lab-page__add-combo-btn" data-add-combo-btn>
            Tilf&oslash;j kombination til kurven
          </button>
        </div>

        <script>
          (function() {
            var buckets = document.querySelectorAll('[data-bucket]');
            var addBtn = document.querySelector('[data-add-combo-btn]');

            buckets.forEach(function(bucket) {
              var dataEl = bucket.querySelector('[data-bucket-data]');
              if (!dataEl) return;
              var data;
              try { data = JSON.parse(dataEl.textContent); } catch (e) { return; }

              var glansSel = bucket.querySelector('[data-bucket-glans]');
              var sizeSel = bucket.querySelector('[data-bucket-size]');
              var priceEl = bucket.querySelector('[data-bucket-price]');
              var imageEl = bucket.querySelector('[data-bucket-image]');
              var titleEl = bucket.querySelector('[data-bucket-title]');
              var linkEl = bucket.querySelector('[data-bucket-link]');

              function update() {
                var g = glansSel.value;
                var s = sizeSel.value;
                var v = data[g] && data[g][s];
                if (!v) {
                  bucket.dataset.variantId = '';
                  bucket.classList.add('is-unavailable');
                  return;
                }
                bucket.classList.remove('is-unavailable');
                bucket.dataset.variantId = v.id;
                if (priceEl) priceEl.textContent = v.price;
                if (imageEl && v.image) imageEl.src = v.image;
                if (titleEl) titleEl.textContent = v.title;
                if (linkEl) linkEl.href = v.url;
              }

              glansSel.addEventListener('change', update);
              sizeSel.addEventListener('change', update);
              update();
            });

            if (!addBtn) return;
            var originalText = addBtn.textContent;

            addBtn.addEventListener('click', function() {
              var items = [];
              buckets.forEach(function(b) {
                var id = b.dataset.variantId;
                if (id) items.push({ id: Number(id), quantity: 1 });
              });
              if (items.length === 0) return;

              addBtn.disabled = true;
              addBtn.textContent = 'Tilføjer...';

              fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: items })
              })
              .then(function(res) {
                if (!res.ok) throw new Error('Failed');
                return res.json();
              })
              .then(function() {
                addBtn.textContent = 'Tilføjet!';
                setTimeout(function() { window.location.href = '/cart'; }, 600);
              })
              .catch(function() {
                addBtn.textContent = 'Noget gik galt – prøv igen';
                addBtn.disabled = false;
                setTimeout(function() { addBtn.textContent = originalText; }, 2000);
              });
            });
          })();
        </script>
      </div>
    {%- endif -%}
  {%- else -%}
    <p style="text-align: center; opacity: 0.5;">Ingen farvekombination fundet.</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .color-lab-page__hero {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .color-lab-page__title {
    margin: 0;
    font-size: 2rem;
    line-height: 1.2;
  }

  .color-lab-page__description {
    margin: 8px 0 0;
    opacity: 0.7;
    font-size: 1rem;
    line-height: 1.5;
  }

  .color-lab-page__palette {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 32px;
  }

  .color-lab-page__color {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .color-lab-page__swatch {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .color-lab-page__color-name {
    font-size: 0.8rem;
    font-weight: 500;
    color: #000;
  }

  .color-lab-page__color-code {
    font-size: 0.7rem;
    color: #b0b0b0;
  }

  .color-lab-page__hex {
    font-size: 0.75rem;
    opacity: 0.5;
    font-family: monospace;
    text-transform: uppercase;
  }

  .color-lab-page__gallery {
    margin-top: 64px;
  }

  .color-lab-page__gallery-heading {
    text-align: center;
    margin: 0 0 32px;
    font-size: 1.1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.6;
  }

  .color-lab-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    gap: 16px;
  }

  .color-lab-page__image-wrapper {
    border-radius: 12px;
    overflow: hidden;
  }

  .color-lab-page__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .color-lab-page__no-images {
    text-align: center;
    margin-top: 48px;
    opacity: 0.5;
  }

  .color-lab-page__products {
    margin-top: 64px;
  }

  .color-lab-page__products-heading {
    text-align: center;
    margin: 0 0 28px;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.45;
  }

  .color-lab-page__buckets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .color-lab-page__bucket {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .color-lab-page__bucket:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  .color-lab-page__bucket.is-unavailable {
    opacity: 0.5;
  }

  .color-lab-page__bucket-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .color-lab-page__bucket-image-wrapper {
    aspect-ratio: 1 / 1;
    background: rgba(0, 0, 0, 0.02);
    overflow: hidden;
  }

  .color-lab-page__bucket-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .color-lab-page__bucket-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
  }

  .color-lab-page__bucket-color {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .color-lab-page__bucket-swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.1);
    flex-shrink: 0;
  }

  .color-lab-page__bucket-color-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    min-width: 0;
  }

  .color-lab-page__bucket-color-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #000;
  }

  .color-lab-page__bucket-color-code {
    font-size: 0.7rem;
    color: #b0b0b0;
    margin-top: 2px;
  }

  .color-lab-page__bucket-product-title {
    font-size: 0.8rem;
    margin: 0;
    opacity: 0.6;
  }

  .color-lab-page__bucket-options {
    display: flex;
    gap: 8px;
  }

  .color-lab-page__bucket-option {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .color-lab-page__bucket-option-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.55;
  }

  .color-lab-page__bucket-option select {
    width: 100%;
    padding: 6px 8px;
    font-size: 0.85rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
  }

  .color-lab-page__bucket-price {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
  }

  .color-lab-page__add-combo {
    text-align: center;
    margin-top: 24px;
  }

  .color-lab-page__add-combo-btn {
    display: inline-block;
    padding: 14px 36px;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    background: rgb(var(--color-button-rgb, 45 45 45));
    color: rgb(var(--color-button-label-rgb, 255 255 255));
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .color-lab-page__add-combo-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .color-lab-page__add-combo-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  @media screen and (min-width: 750px) {
    .color-lab-page__title {
      font-size: 2.5rem;
    }

    .color-lab-page__swatch {
      width: 96px;
      height: 96px;
    }

    .color-lab-page__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      max-height: 560px;
    }

    .color-lab-page__image-wrapper--1 {
      grid-column: 1;
      grid-row: 1;
    }

    .color-lab-page__image-wrapper--2 {
      grid-column: 1;
      grid-row: 2;
    }

    .color-lab-page__image-wrapper--3 {
      grid-column: 2;
      grid-row: 1 / 3;
    }
  }

  @media screen and (max-width: 749px) {
    .color-lab-page__palette {
      gap: 16px;
    }

    .color-lab-page__swatch {
      width: 56px;
      height: 56px;
    }
  }
{% endstylesheet %}


{% schema %}
{
  "name": "Colorlab – Side",
  "class": "kmeconsulting-color-lab-page",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Maling-spande"
    },
    {
      "type": "text",
      "id": "paint_handle_stem",
      "label": "Produkt-handle stem",
      "info": "Eks. 'vaegmaling' giver 'vaegmaling-glans-5', 'vaegmaling-glans-7' osv.",
      "default": "vaegmaling"
    },
    {
      "type": "text",
      "id": "glans_levels",
      "label": "Glans-niveauer (komma-separeret)",
      "default": "5,7,10,20"
    },
    {
      "type": "text",
      "id": "default_glans",
      "label": "Standard glans",
      "default": "5"
    },
    {
      "type": "text",
      "id": "size_levels",
      "label": "Størrelser (komma-separeret)",
      "default": "5L,10L,20L"
    },
    {
      "type": "text",
      "id": "default_size",
      "label": "Standard størrelse",
      "default": "5L"
    },
    {
      "type": "header",
      "content": "Sektionslayout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        {
          "value": "page-width",
          "label": "Sidebredde"
        },
        {
          "value": "full-width",
          "label": "Fuld bredde"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Mellemrum",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
