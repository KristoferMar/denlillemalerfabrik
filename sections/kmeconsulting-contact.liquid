<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="contact-page">
    {%- comment -%} Header {%- endcomment -%}
    <div class="contact-page__header">
      <h1 class="contact-page__title">{{ section.settings.heading }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="contact-page__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Contact info (phone + email) {%- endcomment -%}
    <div class="contact-page__info">
      {%- if section.settings.phone != blank -%}
        <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-page__info-item">
          <svg class="contact-page__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <div class="contact-page__info-text">
            <span class="contact-page__info-label">Telefon</span>
            <span class="contact-page__info-value">{{ section.settings.phone }}</span>
          </div>
        </a>
      {%- endif -%}

      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="contact-page__info-item">
          <svg class="contact-page__icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          <div class="contact-page__info-text">
            <span class="contact-page__info-label">E-mail</span>
            <span class="contact-page__info-value">{{ section.settings.email }}</span>
          </div>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Two columns: B2C and B2B {%- endcomment -%}
    <div class="contact-page__columns">
      {%- comment -%} B2C {%- endcomment -%}
      <div class="contact-page__column">
        <div class="contact-page__column-stripe" style="background-color: {{ section.settings.b2c_accent }};"></div>
        <h2 class="contact-page__column-title">{{ section.settings.b2c_heading }}</h2>
        <div class="contact-page__column-text">{{ section.settings.b2c_text }}</div>
      </div>

      {%- comment -%} B2B {%- endcomment -%}
      <div class="contact-page__column">
        <div class="contact-page__column-stripe" style="background-color: {{ section.settings.b2b_accent }};"></div>
        <h2 class="contact-page__column-title">{{ section.settings.b2b_heading }}</h2>
        <div class="contact-page__column-text">{{ section.settings.b2b_text }}</div>
      </div>
    </div>
  </div>
</div>

<style>
  .contact-page {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .contact-page__header {
    text-align: center;
  }

  .contact-page__title {
    margin: 0 0 8px;
  }

  .contact-page__subheading {
    margin: 0;
    opacity: 0.6;
    max-width: 500px;
    margin-inline: auto;
    line-height: 1.6;
  }

  /* --- Contact info --- */
  .contact-page__info {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media screen and (min-width: 750px) {
    .contact-page__info {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .contact-page__info-item {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    padding: 20px 32px;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
    border-radius: 12px;
    transition: border-color 0.2s ease, transform 0.15s ease;
  }

  .contact-page__info-item:hover {
    border-color: rgb(var(--color-foreground-rgb, 0 0 0) / 0.3);
    transform: translateY(-2px);
  }

  .contact-page__icon {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .contact-page__info-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-page__info-label {
    font-size: 0.8rem;
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .contact-page__info-value {
    font-size: 1.05rem;
    font-weight: 500;
  }

  /* --- Two columns --- */
  .contact-page__columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media screen and (min-width: 750px) {
    .contact-page__columns {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .contact-page__column {
    padding: 32px;
    border: 1.5px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.08);
    border-radius: 12px;
  }

  .contact-page__column-stripe {
    width: 40px;
    height: 3px;
    border-radius: 2px;
    margin-bottom: 16px;
  }

  .contact-page__column-title {
    margin: 0 0 12px;
    font-size: 1.3rem;
  }

  .contact-page__column-text {
    opacity: 0.65;
    line-height: 1.7;
    font-size: 0.95rem;
  }
</style>

{% schema %}
{
  "name": "Kontaktside",
  "class": "kmeconsulting-contact",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Kontakt os"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Underoverskrift",
      "default": "Vi er altid klar til at hjælpe dig med dit næste maleprojekt."
    },
    {
      "type": "header",
      "content": "Kontaktoplysninger"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Telefonnummer",
      "default": "+45 12 34 56 78"
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-mail",
      "default": "info@denlillemalerfabrik.dk"
    },
    {
      "type": "header",
      "content": "Privatkunder (B2C)"
    },
    {
      "type": "text",
      "id": "b2c_heading",
      "label": "Overskrift",
      "default": "Privatkunder"
    },
    {
      "type": "richtext",
      "id": "b2c_text",
      "label": "Tekst",
      "default": "<p>Har du spørgsmål til vores farver, produkter eller dit maleprojekt? Vi hjælper dig gerne med at finde den rigtige løsning. Ring til os eller send en e-mail – vi vender tilbage hurtigst muligt.</p>"
    },
    {
      "type": "color",
      "id": "b2c_accent",
      "label": "Accentfarve",
      "default": "#A3C1CE"
    },
    {
      "type": "header",
      "content": "Erhvervskunder (B2B)"
    },
    {
      "type": "text",
      "id": "b2b_heading",
      "label": "Overskrift",
      "default": "Erhvervs- og storkunder"
    },
    {
      "type": "richtext",
      "id": "b2b_text",
      "label": "Tekst",
      "default": "<p>Er du arkitekt, professionel maler eller virksomhed med behov for større mængder maling? Vi tilbyder skræddersyede aftaler til erhvervskunder – uanset om det drejer sig om et enkelt større projekt eller løbende indkøb. Kontakt os direkte, så finder vi sammen den bedste løsning for dig.</p>"
    },
    {
      "type": "color",
      "id": "b2b_accent",
      "label": "Accentfarve",
      "default": "#CDBA9E"
    },
    {
      "type": "header",
      "content": "Sektionslayout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Bredde",
      "options": [
        { "value": "page-width", "label": "Sidebredde" },
        { "value": "full-width", "label": "Fuld bredde" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farveskema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bund",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Kontaktside",
      "category": "Sider"
    }
  ]
}
{% endschema %}
